<Window x:Class="HabitFlow.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:local="clr-namespace:HabitFlow"
        mc:Ignorable="d"
        Title="Статистика и графики"
        Height="1200" Width="1300"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded">

    <Border CornerRadius="20" Background="#F5F7FA" Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#33000000" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- ==================== ВЕРХНЯЯ ПАНЕЛЬ ==================== -->
            <Border Grid.Row="0" Background="White" CornerRadius="20,20,0,0" Padding="25,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Заголовок -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📊" FontSize="28" Margin="0,0,10,0"/>
                        <TextBlock Text="Статистика и аналитика" FontSize="24" FontWeight="SemiBold" Foreground="#333"/>
                    </StackPanel>

                    <!-- Период и фильтры -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Background="#F0F0F0" CornerRadius="15" Padding="5">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="rbWeek" Content="Неделя" Margin="10,0" IsChecked="True" Checked="Period_Changed"/>
                                <RadioButton x:Name="rbMonth" Content="Месяц" Margin="10,0" Checked="Period_Changed"/>
                                <RadioButton x:Name="rbQuarter" Content="Квартал" Margin="10,0" Checked="Period_Changed"/>
                                <RadioButton x:Name="rbYear" Content="Год" Margin="10,0" Checked="Period_Changed"/>
                                <RadioButton x:Name="rbAll" Content="Всё время" Margin="10,0" Checked="Period_Changed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Кнопки управления -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="btnMinimize" Content="─" Width="35" Height="35" 
                                Background="Transparent" BorderBrush="Transparent" 
                                FontSize="18" Cursor="Hand" Click="btnMinimize_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="17.5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="btnClose" Content="✕" Width="35" Height="35" 
                                Background="Transparent" BorderBrush="Transparent" 
                                FontSize="18" Foreground="#E74C3C" Cursor="Hand" Click="btnClose_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="17.5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== ОСНОВНОЙ КОНТЕНТ ==================== -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ===== БЛОК 1: Выбор привычки и общая статистика ===== -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="350"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Левая колонка: Выбор привычки -->
                        <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Выберите привычку" 
                                           FontSize="16" FontWeight="SemiBold" Foreground="#333" 
                                           Margin="0,0,0,15"/>

                                <ComboBox Grid.Row="1" x:Name="cmbHabitSelector" 
                                          Height="45" FontSize="14"
                                          DisplayMemberPath="HabitName"
                                          SelectedValuePath="HabitId"
                                          SelectionChanged="cmbHabitSelector_SelectionChanged"
                                          Margin="0,0,0,15">
                                    <ComboBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </ComboBox.Resources>
                                </ComboBox>

                                <RadioButton Grid.Row="2" x:Name="rbAllHabits" 
                                             Content="Показать статистику по всем привычкам"
                                             Margin="0,0,0,15"
                                             Checked="rbAllHabits_Checked"/>

                                <Border Grid.Row="3" Background="#F8F9FA" CornerRadius="10" Padding="15">
                                    <StackPanel>
                                        <TextBlock Text="Быстрая статистика" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Всего записей" FontSize="11" Foreground="#999"/>
                                                <TextBlock x:Name="txtQuickTotalRecords" Text="0" FontSize="18" FontWeight="Bold" Foreground="#333"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Выполнено" FontSize="11" Foreground="#999"/>
                                                <TextBlock x:Name="txtQuickCompleted" Text="0" FontSize="18" FontWeight="Bold" Foreground="#4CAF50"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Пропущено" FontSize="11" Foreground="#999"/>
                                                <TextBlock x:Name="txtQuickSkipped" Text="0" FontSize="18" FontWeight="Bold" Foreground="#F39C12"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Процент" FontSize="11" Foreground="#999"/>
                                                <TextBlock x:Name="txtQuickPercent" Text="0%" FontSize="18" FontWeight="Bold" Foreground="#3498DB"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Правая колонка: Основные показатели -->
                        <Border Grid.Column="2" Background="White" CornerRadius="15" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Ключевые показатели" 
                                           FontSize="16" FontWeight="SemiBold" Foreground="#333" 
                                           Margin="0,0,0,20"/>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Текущая серия -->
                                    <Border Grid.Column="0" Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,0,5,0">
                                        <StackPanel>
                                            <TextBlock Text="🔥 Текущая серия" FontSize="12" Foreground="#999" Margin="0,0,0,5"/>
                                            <TextBlock x:Name="txtCurrentStreak" Text="0" FontSize="28" FontWeight="Bold" Foreground="#4CAF50"/>
                                            <TextBlock x:Name="txtCurrentStreakDate" Text="дней" FontSize="11" Foreground="#999"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Максимальная серия -->
                                    <Border Grid.Column="1" Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="5">
                                        <StackPanel>
                                            <TextBlock Text="🏆 Рекорд" FontSize="12" Foreground="#999" Margin="0,0,0,5"/>
                                            <TextBlock x:Name="txtMaxStreak" Text="0" FontSize="28" FontWeight="Bold" Foreground="#E67E22"/>
                                            <TextBlock x:Name="txtMaxStreakDate" Text="дней" FontSize="11" Foreground="#999"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Всего выполнений -->
                                    <Border Grid.Column="2" Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="5">
                                        <StackPanel>
                                            <TextBlock Text="✅ Выполнено" FontSize="12" Foreground="#999" Margin="0,0,0,5"/>
                                            <TextBlock x:Name="txtTotalCompleted" Text="0" FontSize="28" FontWeight="Bold" Foreground="#3498DB"/>
                                            <TextBlock x:Name="txtTotalCompletedPercent" Text="0%" FontSize="11" Foreground="#999"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Всего пропусков -->
                                    <Border Grid.Column="3" Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="5,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="➖ Пропуски" FontSize="12" Foreground="#999" Margin="0,0,0,5"/>
                                            <TextBlock x:Name="txtTotalSkipped" Text="0" FontSize="28" FontWeight="Bold" Foreground="#E74C3C"/>
                                            <TextBlock x:Name="txtTotalSkippedPercent" Text="0%" FontSize="11" Foreground="#999"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ===== БЛОК 2: График выполнения по дням ===== -->
                    <Border Grid.Row="2" Background="White" CornerRadius="15" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Ежедневное выполнение" 
                                           FontSize="16" FontWeight="SemiBold" Foreground="#333"/>

                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Border Background="#4CAF50" Width="12" Height="12" CornerRadius="3" Margin="0,0,5,0"/>
                                    <TextBlock Text="Выполнено" FontSize="11" Foreground="#666" Margin="0,0,15,0"/>
                                    <Border Background="#F39C12" Width="12" Height="12" CornerRadius="3" Margin="0,0,5,0"/>
                                    <TextBlock Text="Пропущено" FontSize="11" Foreground="#666"/>
                                </StackPanel>
                            </Grid>

                            <lvc:CartesianChart Grid.Row="1" Name="DailyChart" Height="300" Margin="0,20,0,0">
                                <lvc:CartesianChart.Series>
                                    <lvc:ColumnSeries Title="Выполнено" Values="{Binding CompletedDailyValues}" 
                                                      Fill="#4CAF50" ColumnPadding="0" MaxColumnWidth="30"/>
                                    <lvc:ColumnSeries Title="Пропущено" Values="{Binding SkippedDailyValues}" 
                                                      Fill="#F39C12" ColumnPadding="0" MaxColumnWidth="30"/>
                                </lvc:CartesianChart.Series>

                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="Дата" Labels="{Binding DailyLabels}" 
                                              FontSize="10" Foreground="#999">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Step="1" StrokeThickness="0.5" Stroke="#EEE"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisX>

                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="Количество" LabelFormatter="{Binding YFormatter}" 
                                              FontSize="10" Foreground="#999">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator StrokeThickness="0.5" Stroke="#EEE"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </Grid>
                    </Border>

                    <!-- ===== БЛОК 3: Недельная и месячная статистика ===== -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Левая колонка: По дням недели -->
                        <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Статистика по дням недели" 
                                           FontSize="16" FontWeight="SemiBold" Foreground="#333" 
                                           Margin="0,0,0,15"/>

                                <lvc:CartesianChart Grid.Row="1" Name="WeekdayChart" Height="250">
                                    <lvc:CartesianChart.Series>
                                        <lvc:ColumnSeries Title="Выполнено" Values="{Binding WeekdayValues}" 
                                                          Fill="#4CAF50" ColumnPadding="5" MaxColumnWidth="40"/>
                                    </lvc:CartesianChart.Series>

                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Labels="{Binding WeekdayLabels}" FontSize="11" Foreground="#999">
                                            <lvc:Axis.Separator>
                                                <lvc:Separator Step="1" StrokeThickness="0"/>
                                            </lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisX>

                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis LabelFormatter="{Binding YFormatter}" FontSize="10" Foreground="#999">
                                            <lvc:Axis.Separator>
                                                <lvc:Separator StrokeThickness="0.5" Stroke="#EEE"/>
                                            </lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </Grid>
                        </Border>

                        <!-- Правая колонка: По месяцам -->
                        <Border Grid.Column="2" Background="White" CornerRadius="15" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Статистика по месяцам" 
                                           FontSize="16" FontWeight="SemiBold" Foreground="#333" 
                                           Margin="0,0,0,15"/>

                                <lvc:CartesianChart Grid.Row="1" Name="MonthlyChart" Height="250">
                                    <lvc:CartesianChart.Series>
                                        <lvc:LineSeries Title="Процент выполнения" Values="{Binding MonthlyPercentValues}" 
                                                        Fill="Transparent" Stroke="#3498DB" StrokeThickness="3" 
                                                        PointGeometrySize="8" PointForeground="#3498DB"/>
                                    </lvc:CartesianChart.Series>

                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Labels="{Binding MonthlyLabels}" FontSize="11" Foreground="#999">
                                            <lvc:Axis.Separator>
                                                <lvc:Separator Step="1" StrokeThickness="0"/>
                                            </lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisX>

                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis Title="%" LabelFormatter="{Binding PercentFormatter}" 
                                                  FontSize="10" Foreground="#999" MinValue="0" MaxValue="100">
                                            <lvc:Axis.Separator>
                                                <lvc:Separator StrokeThickness="0.5" Stroke="#EEE"/>
                                            </lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ===== БЛОК 4: Тепловая карта и круговая диаграмма ===== -->
                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="400"/>
                        </Grid.ColumnDefinitions>

                        <!-- Левая колонка: Тепловая карта (GitHub style) -->
                        <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Тепловая карта активности" 
                                           FontSize="16" FontWeight="SemiBold" Foreground="#333" 
                                           Margin="0,0,0,15"/>

                                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <ItemsControl x:Name="HeatMapControl" Margin="0,0,0,10">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="2">
                                                    <TextBlock Text="{Binding Month}" FontSize="10" Foreground="#999" HorizontalAlignment="Center"/>
                                                    <ItemsControl ItemsSource="{Binding Weeks}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="1">
                                                                    <ItemsControl ItemsSource="{Binding Days}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border Width="14" Height="14" 
                                                                        Background="{Binding Color}" 
                                                                        CornerRadius="3"
                                                                        ToolTip="{Binding ToolTip}"
                                                                        Margin="0,1"/>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- Легенда тепловой карты -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,20,0,0">
                                    <TextBlock Text="Меньше" FontSize="10" Foreground="#999" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <Border Width="14" Height="14" Background="#EBEDF0" CornerRadius="3" Margin="1"/>
                                    <Border Width="14" Height="14" Background="#9BE9A8" CornerRadius="3" Margin="1"/>
                                    <Border Width="14" Height="14" Background="#40C463" CornerRadius="3" Margin="1"/>
                                    <Border Width="14" Height="14" Background="#30A14E" CornerRadius="3" Margin="1"/>
                                    <Border Width="14" Height="14" Background="#216E39" CornerRadius="3" Margin="1"/>
                                    <TextBlock Text="Больше" FontSize="10" Foreground="#999" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Правая колонка: Круговая диаграмма -->
                        <Border Grid.Column="2" Background="White" CornerRadius="15" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Общее распределение" 
                                           FontSize="16" FontWeight="SemiBold" Foreground="#333" 
                                           Margin="0,0,0,15"/>

                                <lvc:PieChart Grid.Row="1" Name="PieChart" Height="250" Margin="0,0,0,15">
                                    <lvc:PieChart.Series>
                                        <lvc:PieSeries Title="Выполнено" Values="{Binding CompletedPieValue}" 
                                                       Fill="#4CAF50" PushOut="0" DataLabels="True" LabelPoint="{Binding PieLabelPoint}"/>
                                        <lvc:PieSeries Title="Пропущено" Values="{Binding SkippedPieValue}" 
                                                       Fill="#F39C12" PushOut="0" DataLabels="True" LabelPoint="{Binding PieLabelPoint}"/>
                                        <lvc:PieSeries Title="Не отмечено" Values="{Binding NotSetPieValue}" 
                                                       Fill="#E0E0E0" PushOut="0" DataLabels="True" LabelPoint="{Binding PieLabelPoint}"/>
                                    </lvc:PieChart.Series>
                                </lvc:PieChart>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Border Width="12" Height="12" Background="#4CAF50" CornerRadius="3" Margin="0,0,5,0"/>
                                        <TextBlock Text="Выполнено" FontSize="11" Foreground="#666"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Border Width="12" Height="12" Background="#F39C12" CornerRadius="3" Margin="0,0,5,0"/>
                                        <TextBlock Text="Пропущено" FontSize="11" Foreground="#666"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Border Width="12" Height="12" Background="#E0E0E0" CornerRadius="3" Margin="0,0,5,0"/>
                                        <TextBlock Text="Не отмечено" FontSize="11" Foreground="#666"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <!-- ==================== НИЖНЯЯ ПАНЕЛЬ ==================== -->
            <Border Grid.Row="2" Background="White" Padding="25,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Мотивационная фраза -->
                    <TextBlock Grid.Column="0" x:Name="txtMotivationPhrase" 
                               Text="Анализируй прогресс, становись лучше! 📈" 
                               Foreground="#666" VerticalAlignment="Center"/>

                    <!-- Кнопка экспорта -->
                    <Button Grid.Column="1" x:Name="btnExport" 
                            Content="📥 Экспорт статистики" 
                            Height="40" Padding="20,0"
                            Background="#3498DB" Foreground="White"
                            BorderBrush="Transparent"
                            FontSize="14" FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="btnExport_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>