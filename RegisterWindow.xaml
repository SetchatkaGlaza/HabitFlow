<Window x:Class="HabitFlow.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HabitFlow"
        mc:Ignorable="d"
        Title="Регистрация - HabitFlow"
        Height="750" Width="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="20" Background="White" Padding="30">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#33000000" Opacity="0.3"/>
        </Border.Effect>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Заголовок и кнопка закрытия -->
                <DockPanel LastChildFill="False" Margin="0,0,0,20">
                    <TextBlock Text="HabitFlow" 
                               FontSize="28" 
                               FontWeight="Bold" 
                               Foreground="#4CAF50"
                               DockPanel.Dock="Left"/>
                    <Button x:Name="btnClose" 
                            Content="✕" 
                            Width="30" 
                            Height="30"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Foreground="#999"
                            FontSize="18"
                            Cursor="Hand"
                            DockPanel.Dock="Right"
                            Click="btnClose_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="15"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </DockPanel>

                <TextBlock Text="Создание аккаунта" 
                           FontSize="24" 
                           FontWeight="SemiBold" 
                           Margin="0,10,0,30"/>

                <!-- Форма регистрации -->
                <TextBlock Text="Имя пользователя" 
                           FontSize="14" 
                           Foreground="#666" 
                           Margin="0,0,0,5"/>
                <TextBox x:Name="txtUsername" 
                         Height="45" 
                         FontSize="16" 
                         Padding="10,0"
                         BorderBrush="#DDD" 
                         BorderThickness="1"
                         Margin="0,0,0,15">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Email" 
                           FontSize="14" 
                           Foreground="#666" 
                           Margin="0,0,0,5"/>
                <TextBox x:Name="txtEmail" 
                         Height="45" 
                         FontSize="16" 
                         Padding="10,0"
                         BorderBrush="#DDD" 
                         BorderThickness="1"
                         Margin="0,0,0,15">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Пароль" 
                           FontSize="14" 
                           Foreground="#666" 
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" 
                             Height="45" 
                             FontSize="16" 
                             Padding="10,0"
                             BorderBrush="#DDD" 
                             BorderThickness="1"
                             Margin="0,0,0,5"
                             PasswordChanged="txtPassword_PasswordChanged">
                    <PasswordBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>

                <!-- Индикатор сложности пароля -->
                <Border x:Name="passwordStrengthIndicator" 
                        Height="5" 
                        CornerRadius="3" 
                        Background="#EEE" 
                        Margin="0,0,0,15">
                    <Border x:Name="passwordStrengthFill" 
                            Width="0" 
                            Height="5" 
                            CornerRadius="3" 
                            Background="#4CAF50" 
                            HorizontalAlignment="Left"/>
                </Border>

                <TextBlock Text="Подтверждение пароля" 
                           FontSize="14" 
                           Foreground="#666" 
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtConfirmPassword" 
                             Height="45" 
                             FontSize="16" 
                             Padding="10,0"
                             BorderBrush="#DDD" 
                             BorderThickness="1"
                             Margin="0,0,0,10"
                             PasswordChanged="txtConfirmPassword_PasswordChanged">
                    <PasswordBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>

                <!-- Блок запоминания пользователя -->
                <CheckBox x:Name="chkRememberMe" 
                          Margin="0,10,0,20"
                          VerticalAlignment="Center">
                    <TextBlock Text="Запомнить меня" FontSize="14" Foreground="#666"/>
                </CheckBox>

                <!-- Кнопка регистрации -->
                <Button x:Name="btnRegister" 
                        Content="Зарегистрироваться" 
                        Height="50" 
                        FontSize="16" 
                        FontWeight="SemiBold"
                        Background="#4CAF50" 
                        Foreground="White"
                        BorderBrush="Transparent"
                        Cursor="Hand"
                        Margin="0,10,0,15"
                        Click="btnRegister_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="1"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#CCC"/>
                                    <Setter Property="Foreground" Value="#666"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Ссылка на авторизацию -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Уже есть аккаунт? " FontSize="14" Foreground="#666"/>
                    <Button x:Name="btnGoToLogin" 
                            Content="Войти" 
                            Background="Transparent" 
                            BorderBrush="Transparent"
                            Foreground="#4CAF50" 
                            FontSize="14" 
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="btnGoToLogin_Click"/>
                </StackPanel>

                <!-- Сообщение об ошибке -->
                <TextBlock x:Name="txtErrorMessage" 
                           Text="" 
                           Foreground="#E74C3C" 
                           FontSize="12" 
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>