<Window x:Class="HabitFlow.ImportExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HabitFlow"
        mc:Ignorable="d"
        Title="Импорт и экспорт данных"
        Height="870" Width="950"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded">

    <Border CornerRadius="20" Background="#F5F7FA" Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#33000000" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- ==================== ВЕРХНЯЯ ПАНЕЛЬ ==================== -->
            <Border Grid.Row="0" Background="White" CornerRadius="20,20,0,0" Padding="25,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Заголовок -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📦" FontSize="28" Margin="0,0,10,0"/>
                        <TextBlock Text="Импорт и экспорт данных" FontSize="24" FontWeight="SemiBold" Foreground="#333"/>
                    </StackPanel>

                    <!-- Статус -->
                    <Border Grid.Column="1" x:Name="borderStatus" Background="#4CAF5020" CornerRadius="15" Padding="15,5" 
                            HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                        <TextBlock x:Name="txtStatus" Text="" Foreground="#4CAF50" FontSize="12"/>
                    </Border>

                    <!-- Кнопки управления -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="btnMinimize" Content="─" Width="35" Height="35" 
                                Background="Transparent" BorderBrush="Transparent" 
                                FontSize="18" Cursor="Hand" Click="btnMinimize_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="17.5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="btnClose" Content="✕" Width="35" Height="35" 
                                Background="Transparent" BorderBrush="Transparent" 
                                FontSize="18" Foreground="#E74C3C" Cursor="Hand" Click="btnClose_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="17.5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== ОСНОВНОЙ КОНТЕНТ ==================== -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ===== БЛОК 1: ЭКСПОРТ ===== -->
                    <Border Grid.Row="0" Background="White" CornerRadius="15" Padding="25">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="📤" FontSize="32" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Экспорт данных" FontSize="20" FontWeight="SemiBold" Foreground="#333"/>
                                    <TextBlock Text="Сохраните свои данные в файл для резервного копирования или переноса" 
                                               FontSize="12" Foreground="#666" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,20,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Формат файла -->
                                <Border Grid.Column="0" Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,0,5,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Формат файла" 
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                                   Margin="0,0,0,10"/>

                                        <ComboBox x:Name="cmbExportFormat" Height="35" SelectedIndex="0">
                                            <ComboBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="8"/>
                                                </Style>
                                            </ComboBox.Resources>
                                            <ComboBoxItem Content="JSON (рекомендуется)" Tag="json" IsSelected="True"/>
                                            <ComboBoxItem Content="CSV (табличный)" Tag="csv"/>
                                            <ComboBoxItem Content="Excel (XLSX)" Tag="xlsx"/>
                                            <ComboBoxItem Content="XML" Tag="xml"/>
                                        </ComboBox>
                                    </Grid>
                                </Border>

                                <!-- Что экспортировать -->
                                <Border Grid.Column="1" Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="5">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Что экспортировать" 
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                                   Margin="0,0,0,10"/>

                                        <StackPanel Grid.Row="1">
                                            <CheckBox x:Name="chkExportHabits" Content="Привычки" IsChecked="True" Margin="0,0,0,5"/>
                                            <CheckBox x:Name="chkExportRecords" Content="История отметок" IsChecked="True" Margin="0,0,0,5"/>
                                            <CheckBox x:Name="chkExportSettings" Content="Настройки" IsChecked="True"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Дополнительные опции -->
                                <Border Grid.Column="2" Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="5,0,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Дополнительно" 
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                                   Margin="0,0,0,10"/>

                                        <StackPanel Grid.Row="1">
                                            <CheckBox x:Name="chkExportWithDates" Content="Включить даты создания" IsChecked="True" Margin="0,0,0,5"/>
                                            <CheckBox x:Name="chkExportPretty" Content="Форматировать JSON" IsChecked="True" Margin="0,0,0,5"/>
                                            <CheckBox x:Name="chkExportEncrypt" Content="Зашифровать файл"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Информация о данных -->
                            <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                                        <TextBlock Text="📊" FontSize="16" Margin="0,0,5,0"/>
                                        <TextBlock x:Name="txtExportStats" Text="Привычек: 0, Записей: 0" FontSize="12" Foreground="#666"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button x:Name="btnExport" 
                                                Content="📥 Экспортировать" 
                                                Height="40" Padding="25,0"
                                                Background="#4CAF50" Foreground="White"
                                                BorderBrush="Transparent"
                                                FontSize="14" FontWeight="SemiBold"
                                                Cursor="Hand"
                                                Click="btnExport_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ===== БЛОК 2: ИМПОРТ ===== -->
                    <Border Grid.Row="2" Background="White" CornerRadius="15" Padding="25">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="📥" FontSize="32" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Импорт данных" FontSize="20" FontWeight="SemiBold" Foreground="#333"/>
                                    <TextBlock Text="Загрузите данные из ранее созданного файла" 
                                               FontSize="12" Foreground="#666" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,20,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Режим импорта -->
                                <Border Grid.Column="0" Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,0,5,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Режим импорта" 
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                                   Margin="0,0,0,10"/>

                                        <StackPanel Grid.Row="1">
                                            <RadioButton x:Name="rbImportMerge" Content="Объединить с существующими" GroupName="ImportMode" IsChecked="True" Margin="0,0,0,5"/>
                                            <RadioButton x:Name="rbImportReplace" Content="Заменить все данные" GroupName="ImportMode" Margin="0,0,0,5"/>
                                            <RadioButton x:Name="rbImportSelective" Content="Выборочный импорт" GroupName="ImportMode"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Выборочный импорт (доступен при выборе режима) -->
                                <Border Grid.Column="1" Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="5,0,0,0"
                                        IsEnabled="{Binding ElementName=rbImportSelective, Path=IsChecked}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Выберите данные для импорта" 
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                                   Margin="0,0,0,10"/>

                                        <StackPanel Grid.Row="1">
                                            <CheckBox x:Name="chkImportHabits" Content="Привычки" IsChecked="True" Margin="0,0,0,5"/>
                                            <CheckBox x:Name="chkImportRecords" Content="История отметок" IsChecked="True" Margin="0,0,0,5"/>
                                            <CheckBox x:Name="chkImportSettings" Content="Настройки" IsChecked="True"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Выбор файла и импорт -->
                            <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="10" Padding="15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0" x:Name="txtImportFile" 
                                             Height="40" Padding="10,0"
                                             BorderBrush="#DDD" BorderThickness="1"
                                             IsReadOnly="True"
                                             Text="Файл не выбран">
                                        <TextBox.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </TextBox.Resources>
                                    </TextBox>

                                    <Button Grid.Column="1" x:Name="btnBrowseFile" 
                                            Content="📂 Обзор" 
                                            Height="40" Width="80"
                                            Background="#3498DB" Foreground="White"
                                            BorderBrush="Transparent"
                                            FontSize="12" FontWeight="SemiBold"
                                            Cursor="Hand"
                                            Margin="5,0,5,0"
                                            Click="btnBrowseFile_Click"/>

                                    <Button Grid.Column="2" x:Name="btnImport" 
                                            Content="📤 Импортировать" 
                                            Height="40" Width="120"
                                            Background="#F39C12" Foreground="White"
                                            BorderBrush="Transparent"
                                            FontSize="12" FontWeight="SemiBold"
                                            Cursor="Hand"
                                            IsEnabled="False"
                                            Click="btnImport_Click"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ===== БЛОК 3: СИНХРОНИЗАЦИЯ ===== -->
                    <Border Grid.Row="4" Background="White" CornerRadius="15" Padding="25">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="🔄" FontSize="32" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Облачная синхронизация" FontSize="20" FontWeight="SemiBold" Foreground="#333"/>
                                    <TextBlock Text="Синхронизируйте данные между устройствами" 
                                               FontSize="12" Foreground="#666" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="10" Padding="20" Margin="0,20,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Статус синхронизации -->
                                    <Grid Grid.Row="0" Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="10" Height="10" Background="#E74C3C" CornerRadius="5" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1" Text="Облачная синхронизация не настроена" 
                                                   FontSize="13" Foreground="#666" VerticalAlignment="Center"/>

                                        <Button Grid.Column="2" x:Name="btnConfigureSync" 
                                                Content="Настроить" 
                                                Height="30" Padding="15,0"
                                                Background="#3498DB" Foreground="White"
                                                BorderBrush="Transparent"
                                                FontSize="11" FontWeight="SemiBold"
                                                Cursor="Hand"
                                                Click="btnConfigureSync_Click"/>
                                    </Grid>

                                    <!-- Настройки синхронизации (скрыты по умолчанию) -->
                                    <Border x:Name="borderSyncSettings" Grid.Row="1" Visibility="Collapsed">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Text="Выберите облачный сервис:" 
                                                       FontSize="12" Foreground="#333" Margin="0,0,0,10"/>

                                            <ComboBox Grid.Row="1" x:Name="cmbSyncService" Height="35" Margin="0,0,0,15">
                                                <ComboBox.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </ComboBox.Resources>
                                                <ComboBoxItem Content="Google Drive" IsSelected="True"/>
                                                <ComboBoxItem Content="OneDrive"/>
                                                <ComboBoxItem Content="Dropbox"/>
                                                <ComboBoxItem Content="Яндекс.Диск"/>
                                            </ComboBox>

                                            <Button x:Name="btnConnectSync" 
                                                    Content="🔗 Подключить" 
                                                    Height="35"
                                                    Background="#4CAF50" Foreground="White"
                                                    BorderBrush="Transparent"
                                                    FontSize="12" FontWeight="SemiBold"
                                                    Cursor="Hand"
                                                    Click="btnConnectSync_Click"/>
                                        </Grid>
                                    </Border>

                                    <!-- Информация о последней синхронизации -->
                                    <TextBlock Grid.Row="2" x:Name="txtLastSync" 
                                               Text="Последняя синхронизация: никогда" 
                                               FontSize="11" Foreground="#999" 
                                               Margin="0,15,0,0" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ===== БЛОК 4: АВТОМАТИЧЕСКОЕ РЕЗЕРВНОЕ КОПИРОВАНИЕ ===== -->
                    <Border Grid.Row="6" Background="White" CornerRadius="15" Padding="25">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="⏱️" FontSize="32" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Автоматическое резервное копирование" FontSize="20" FontWeight="SemiBold" Foreground="#333"/>
                                    <TextBlock Text="Настройте регулярное сохранение ваших данных" 
                                               FontSize="12" Foreground="#666" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="10" Padding="20" Margin="0,20,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Включение авто-бэкапа -->
                                    <CheckBox x:Name="chkAutoBackup" 
                                              Content="Включить автоматическое резервное копирование" 
                                              FontSize="14" FontWeight="SemiBold" Foreground="#333"
                                              Checked="AutoBackup_Changed"
                                              Unchecked="AutoBackup_Changed"
                                              Margin="0,0,0,15"/>

                                    <!-- Настройки авто-бэкапа -->
                                    <Grid Grid.Row="1" Margin="20,0,0,15" IsEnabled="{Binding ElementName=chkAutoBackup, Path=IsChecked}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="Периодичность" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                                            <ComboBox x:Name="cmbBackupFrequency" Height="35">
                                                <ComboBox.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </ComboBox.Resources>
                                                <ComboBoxItem Content="Каждый день" Tag="daily" IsSelected="True"/>
                                                <ComboBoxItem Content="Раз в неделю" Tag="weekly"/>
                                                <ComboBoxItem Content="Раз в месяц" Tag="monthly"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <TextBlock Text="Макс. количество копий" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                                            <ComboBox x:Name="cmbBackupMaxCopies" Height="35">
                                                <ComboBox.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </ComboBox.Resources>
                                                <ComboBoxItem Content="3 последние" Tag="3" IsSelected="True"/>
                                                <ComboBoxItem Content="5 последних" Tag="5"/>
                                                <ComboBoxItem Content="10 последних" Tag="10"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Путь для сохранения -->
                                    <Grid Grid.Row="2" Margin="20,0,0,0" IsEnabled="{Binding ElementName=chkAutoBackup, Path=IsChecked}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0" x:Name="txtBackupPath" 
                                                 Height="35" Padding="10,0"
                                                 BorderBrush="#DDD" BorderThickness="1"
                                                 IsReadOnly="True"
                                                 Text="{Binding BackupPath}">
                                            <TextBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="8"/>
                                                </Style>
                                            </TextBox.Resources>
                                        </TextBox>

                                        <Button Grid.Column="1" x:Name="btnBrowseBackupPath" 
                                                Content="..." 
                                                Height="35" Width="35"
                                                Background="#3498DB" Foreground="White"
                                                BorderBrush="Transparent"
                                                FontSize="14" FontWeight="Bold"
                                                Cursor="Hand"
                                                Margin="5,0,0,0"
                                                Click="btnBrowseBackupPath_Click"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>

            <!-- ==================== НИЖНЯЯ ПАНЕЛЬ ==================== -->
            <Border Grid.Row="2" Background="White" CornerRadius="0,0,20,20" Padding="25,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Информация о последнем действии -->
                    <TextBlock Grid.Column="0" x:Name="txtLastAction" 
                               Text="Готов к работе" 
                               Foreground="#666" VerticalAlignment="Center"/>

                    <!-- Кнопка сохранения настроек -->
                    <Button Grid.Column="1" x:Name="btnSaveSettings" 
                            Content="💾 Сохранить настройки" 
                            Height="40" Padding="15,0"
                            Background="#4CAF50" Foreground="White"
                            BorderBrush="Transparent"
                            FontSize="12" FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="btnSaveSettings_Click"/>

                    <!-- Кнопка закрытия -->
                    <Button Grid.Column="3" x:Name="btnBack" 
                            Content="Закрыть" 
                            Height="40" Width="100"
                            Background="Transparent" 
                            BorderBrush="#DDD" BorderThickness="1.5"
                            Foreground="#666"
                            Cursor="Hand"
                            Click="btnBack_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>