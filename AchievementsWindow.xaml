<Window x:Class="HabitFlow.AchievementsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HabitFlow"
        mc:Ignorable="d"
        Title="Достижения и награды"
        Height="800" Width="1100"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded">

    <Border CornerRadius="20" Background="#F5F7FA" Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#33000000" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- ==================== ВЕРХНЯЯ ПАНЕЛЬ ==================== -->
            <Border Grid.Row="0" Background="White" CornerRadius="20,20,0,0" Padding="25,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Заголовок -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🏆" FontSize="28" Margin="0,0,10,0"/>
                        <TextBlock Text="Достижения и награды" FontSize="24" FontWeight="SemiBold" Foreground="#333"/>
                    </StackPanel>

                    <!-- Общий прогресс -->
                    <Border Grid.Column="1" Background="#F0F0F0" CornerRadius="15" Padding="15,5" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="txtTotalAchievements" Text="0/30" FontSize="16" FontWeight="Bold" Foreground="#333" Margin="0,0,10,0"/>
                            <TextBlock Text="достижений получено" FontSize="14" Foreground="#666"/>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки управления -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="btnMinimize" Content="─" Width="35" Height="35" 
                                Background="Transparent" BorderBrush="Transparent" 
                                FontSize="18" Cursor="Hand" Click="btnMinimize_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="17.5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="btnClose" Content="✕" Width="35" Height="35" 
                                Background="Transparent" BorderBrush="Transparent" 
                                FontSize="18" Foreground="#E74C3C" Cursor="Hand" Click="btnClose_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="17.5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== ОСНОВНОЙ КОНТЕНТ ==================== -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ===== БЛОК 1: Статистика игрока ===== -->
                    <Border Grid.Row="0" Background="White" CornerRadius="15" Padding="25">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Уровень -->
                            <Border Grid.Column="0" CornerRadius="15" Padding="20" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FFD700" Offset="0"/>
                                        <GradientStop Color="#FFA500" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock x:Name="txtLevel" Text="1" FontSize="42" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Уровень" FontSize="14" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Очки опыта -->
                            <Border Grid.Column="1" Background="#F8F9FA" CornerRadius="15" Padding="20" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="Опыт" FontSize="14" Foreground="#999" Margin="0,0,0,5"/>
                                    <TextBlock x:Name="txtXP" Text="0" FontSize="28" FontWeight="Bold" Foreground="#333"/>
                                    <ProgressBar x:Name="progressXP" Height="8" Margin="0,10,0,0" 
                                                 Minimum="0" Maximum="100" Value="0"
                                                 Foreground="#4CAF50" Background="#EEE"/>
                                    <TextBlock x:Name="txtXPNextLevel" Text="0/100 до след. уровня" FontSize="11" Foreground="#999" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Очки достижений -->
                            <Border Grid.Column="2" Background="#F8F9FA" CornerRadius="15" Padding="20" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="Очки достижений" FontSize="14" Foreground="#999" Margin="0,0,0,5"/>
                                    <TextBlock x:Name="txtAchievementPoints" Text="0" FontSize="28" FontWeight="Bold" Foreground="#3498DB"/>
                                    <TextBlock Text="всего получено" FontSize="11" Foreground="#999" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Рейтинг -->
                            <Border Grid.Column="3" Background="#F8F9FA" CornerRadius="15" Padding="20" Margin="10,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Текущий ранг" FontSize="14" Foreground="#999" Margin="0,0,0,5"/>
                                    <TextBlock x:Name="txtRank" Text="Новичок" FontSize="18" FontWeight="Bold" Foreground="#E67E22"/>
                                    <TextBlock x:Name="txtNextRank" Text="Следующий: Ученик" FontSize="11" Foreground="#999" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ===== БЛОК 2: Категории достижений ===== -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Категория: Серии -->
                        <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="15" Margin="0,0,5,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Color="#1A000000" Opacity="0.05"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="🔥 Серии" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock x:Name="txtStreakCategoryProgress" Text="0/6" FontSize="24" FontWeight="Bold" Foreground="#4CAF50"/>
                                    <TextBlock Text=" получено" FontSize="12" Foreground="#999" VerticalAlignment="Bottom" Margin="5,0,0,3"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Категория: Количество -->
                        <Border Grid.Column="1" Background="White" CornerRadius="15" Padding="15" Margin="5">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Color="#1A000000" Opacity="0.05"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="✅ Выполнения" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock x:Name="txtCountCategoryProgress" Text="0/6" FontSize="24" FontWeight="Bold" Foreground="#3498DB"/>
                                    <TextBlock Text=" получено" FontSize="12" Foreground="#999" VerticalAlignment="Bottom" Margin="5,0,0,3"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Категория: Привычки -->
                        <Border Grid.Column="2" Background="White" CornerRadius="15" Padding="15" Margin="5">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Color="#1A000000" Opacity="0.05"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="📋 Привычки" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock x:Name="txtHabitsCategoryProgress" Text="0/6" FontSize="24" FontWeight="Bold" Foreground="#E67E22"/>
                                    <TextBlock Text=" получено" FontSize="12" Foreground="#999" VerticalAlignment="Bottom" Margin="5,0,0,3"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Категория: Особые -->
                        <Border Grid.Column="3" Background="White" CornerRadius="15" Padding="15" Margin="5,0,0,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Color="#1A000000" Opacity="0.05"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="⭐ Особые" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock x:Name="txtSpecialCategoryProgress" Text="0/6" FontSize="24" FontWeight="Bold" Foreground="#9B59B6"/>
                                    <TextBlock Text=" получено" FontSize="12" Foreground="#999" VerticalAlignment="Bottom" Margin="5,0,0,3"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ===== БЛОК 3: Достижения - Серии ===== -->
                    <Border Grid.Row="4" Background="White" CornerRadius="15" Padding="25">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="🔥 Достижения за серии" 
                                       FontSize="18" FontWeight="SemiBold" Foreground="#333" 
                                       Margin="0,0,0,20"/>

                            <ItemsControl Grid.Row="1" x:Name="StreakAchievementsList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="180" Height="200" 
                                                Background="{Binding BackgroundColor}" 
                                                CornerRadius="15" Margin="0,0,15,15"
                                                BorderBrush="{Binding BorderColor}"
                                                BorderThickness="2"
                                                Opacity="{Binding Opacity}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="80"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <!-- Иконка -->
                                                <Border Grid.Row="0" Background="{Binding IconBgColor}" 
                                                        CornerRadius="40" Width="60" Height="60" 
                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Icon}" FontSize="32" 
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>

                                                <!-- Информация -->
                                                <StackPanel Grid.Row="1" Margin="10" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" 
                                                               FontSize="14" FontWeight="Bold" 
                                                               Foreground="{Binding TextColor}"
                                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                                    <TextBlock Text="{Binding Description}" 
                                                               FontSize="11" Foreground="{Binding TextColor}"
                                                               Opacity="0.8" TextWrapping="Wrap" 
                                                               TextAlignment="Center" Margin="0,5,0,0"/>
                                                    <Border Background="{Binding ProgressBgColor}" 
                                                            CornerRadius="10" Padding="5" Margin="0,10,0,0">
                                                        <TextBlock Text="{Binding ProgressText}" 
                                                                   FontSize="10" FontWeight="Bold" 
                                                                   Foreground="{Binding ProgressTextColor}"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Бейдж получено -->
                                                <Border x:Name="AchievedBadge" Grid.RowSpan="2"
                                                        Width="30" Height="30" Background="#4CAF50"
                                                        CornerRadius="15" HorizontalAlignment="Right" 
                                                        VerticalAlignment="Top" Margin="5"
                                                        Visibility="{Binding AchievedVisibility}">
                                                    <TextBlock Text="✓" FontSize="18" FontWeight="Bold" 
                                                               Foreground="White" HorizontalAlignment="Center" 
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- ===== БЛОК 4: Достижения - Количество выполнений ===== -->
                    <Border Grid.Row="6" Background="White" CornerRadius="15" Padding="25">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="✅ Достижения за количество выполнений" 
                                       FontSize="18" FontWeight="SemiBold" Foreground="#333" 
                                       Margin="0,0,0,20"/>

                            <ItemsControl Grid.Row="1" x:Name="CountAchievementsList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="180" Height="200" 
                                                Background="{Binding BackgroundColor}" 
                                                CornerRadius="15" Margin="0,0,15,15"
                                                BorderBrush="{Binding BorderColor}"
                                                BorderThickness="2"
                                                Opacity="{Binding Opacity}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="80"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <!-- Иконка -->
                                                <Border Grid.Row="0" Background="{Binding IconBgColor}" 
                                                        CornerRadius="40" Width="60" Height="60" 
                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Icon}" FontSize="32" 
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>

                                                <!-- Информация -->
                                                <StackPanel Grid.Row="1" Margin="10" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" 
                                                               FontSize="14" FontWeight="Bold" 
                                                               Foreground="{Binding TextColor}"
                                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                                    <TextBlock Text="{Binding Description}" 
                                                               FontSize="11" Foreground="{Binding TextColor}"
                                                               Opacity="0.8" TextWrapping="Wrap" 
                                                               TextAlignment="Center" Margin="0,5,0,0"/>
                                                    <Border Background="{Binding ProgressBgColor}" 
                                                            CornerRadius="10" Padding="5" Margin="0,10,0,0">
                                                        <TextBlock Text="{Binding ProgressText}" 
                                                                   FontSize="10" FontWeight="Bold" 
                                                                   Foreground="{Binding ProgressTextColor}"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Бейдж получено -->
                                                <Border Grid.RowSpan="2"
                                                        Width="30" Height="30" Background="#4CAF50"
                                                        CornerRadius="15" HorizontalAlignment="Right" 
                                                        VerticalAlignment="Top" Margin="5"
                                                        Visibility="{Binding AchievedVisibility}">
                                                    <TextBlock Text="✓" FontSize="18" FontWeight="Bold" 
                                                               Foreground="White" HorizontalAlignment="Center" 
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- ===== БЛОК 5: Достижения - Количество привычек ===== -->
                    <Border Grid.Row="8" Background="White" CornerRadius="15" Padding="25">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="📋 Достижения за количество привычек" 
                                       FontSize="18" FontWeight="SemiBold" Foreground="#333" 
                                       Margin="0,0,0,20"/>

                            <ItemsControl Grid.Row="1" x:Name="HabitsAchievementsList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="180" Height="200" 
                                                Background="{Binding BackgroundColor}" 
                                                CornerRadius="15" Margin="0,0,15,15"
                                                BorderBrush="{Binding BorderColor}"
                                                BorderThickness="2"
                                                Opacity="{Binding Opacity}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="80"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <!-- Иконка -->
                                                <Border Grid.Row="0" Background="{Binding IconBgColor}" 
                                                        CornerRadius="40" Width="60" Height="60" 
                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Icon}" FontSize="32" 
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>

                                                <!-- Информация -->
                                                <StackPanel Grid.Row="1" Margin="10" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" 
                                                               FontSize="14" FontWeight="Bold" 
                                                               Foreground="{Binding TextColor}"
                                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                                    <TextBlock Text="{Binding Description}" 
                                                               FontSize="11" Foreground="{Binding TextColor}"
                                                               Opacity="0.8" TextWrapping="Wrap" 
                                                               TextAlignment="Center" Margin="0,5,0,0"/>
                                                    <Border Background="{Binding ProgressBgColor}" 
                                                            CornerRadius="10" Padding="5" Margin="0,10,0,0">
                                                        <TextBlock Text="{Binding ProgressText}" 
                                                                   FontSize="10" FontWeight="Bold" 
                                                                   Foreground="{Binding ProgressTextColor}"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Бейдж получено -->
                                                <Border Grid.RowSpan="2"
                                                        Width="30" Height="30" Background="#4CAF50"
                                                        CornerRadius="15" HorizontalAlignment="Right" 
                                                        VerticalAlignment="Top" Margin="5"
                                                        Visibility="{Binding AchievedVisibility}">
                                                    <TextBlock Text="✓" FontSize="18" FontWeight="Bold" 
                                                               Foreground="White" HorizontalAlignment="Center" 
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- ===== БЛОК 6: Особые достижения ===== -->
                    <Border Grid.Row="10" Background="White" CornerRadius="15" Padding="25">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="⭐ Особые достижения" 
                                       FontSize="18" FontWeight="SemiBold" Foreground="#333" 
                                       Margin="0,0,0,20"/>

                            <ItemsControl Grid.Row="1" x:Name="SpecialAchievementsList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="180" Height="200" 
                                                Background="{Binding BackgroundColor}" 
                                                CornerRadius="15" Margin="0,0,15,15"
                                                BorderBrush="{Binding BorderColor}"
                                                BorderThickness="2"
                                                Opacity="{Binding Opacity}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="80"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <!-- Иконка -->
                                                <Border Grid.Row="0" Background="{Binding IconBgColor}" 
                                                        CornerRadius="40" Width="60" Height="60" 
                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Icon}" FontSize="32" 
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>

                                                <!-- Информация -->
                                                <StackPanel Grid.Row="1" Margin="10" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" 
                                                               FontSize="14" FontWeight="Bold" 
                                                               Foreground="{Binding TextColor}"
                                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                                    <TextBlock Text="{Binding Description}" 
                                                               FontSize="11" Foreground="{Binding TextColor}"
                                                               Opacity="0.8" TextWrapping="Wrap" 
                                                               TextAlignment="Center" Margin="0,5,0,0"/>
                                                    <Border Background="{Binding ProgressBgColor}" 
                                                            CornerRadius="10" Padding="5" Margin="0,10,0,0">
                                                        <TextBlock Text="{Binding ProgressText}" 
                                                                   FontSize="10" FontWeight="Bold" 
                                                                   Foreground="{Binding ProgressTextColor}"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Бейдж получено -->
                                                <Border Grid.RowSpan="2"
                                                        Width="30" Height="30" Background="#4CAF50"
                                                        CornerRadius="15" HorizontalAlignment="Right" 
                                                        VerticalAlignment="Top" Margin="5"
                                                        Visibility="{Binding AchievedVisibility}">
                                                    <TextBlock Text="✓" FontSize="18" FontWeight="Bold" 
                                                               Foreground="White" HorizontalAlignment="Center" 
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>

            <!-- ==================== НИЖНЯЯ ПАНЕЛЬ ==================== -->
            <Border Grid.Row="2" Background="White" CornerRadius="0,0,20,20" Padding="25,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Мотивационное сообщение -->
                    <TextBlock Grid.Column="0" x:Name="txtMotivationMessage" 
                               Text="Продолжай в том же духе! Следующее достижение уже близко!" 
                               Foreground="#666" VerticalAlignment="Center"/>

                    <!-- Кнопка закрытия -->
                    <Button Grid.Column="1" x:Name="btnBack" 
                            Content="◀ Закрыть достижения" 
                            Height="40" Padding="20,0"
                            Background="Transparent" 
                            BorderBrush="#DDD" 
                            BorderThickness="1.5"
                            Foreground="#666"
                            Cursor="Hand"
                            Click="btnBack_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>