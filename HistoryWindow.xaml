<Window x:Class="HabitFlow.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HabitFlow"
        mc:Ignorable="d"
        Title="История привычек"
        Height="800" Width="1200"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded">

    <Border CornerRadius="20" Background="#F5F7FA" Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#33000000" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- ==================== ВЕРХНЯЯ ПАНЕЛЬ ==================== -->
            <Border Grid.Row="0" Background="White" CornerRadius="20,20,0,0" Padding="25,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Заголовок -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📜" FontSize="28" Margin="0,0,10,0"/>
                        <TextBlock Text="История привычек" FontSize="24" FontWeight="SemiBold" Foreground="#333"/>
                    </StackPanel>

                    <!-- Навигация по датам -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Background="#F0F0F0" CornerRadius="15" Padding="10">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="btnPrevMonth" Content="◀" Width="35" Height="35" 
                                        Background="Transparent" BorderBrush="Transparent" 
                                        FontSize="16" Cursor="Hand" Click="btnPrevMonth_Click"
                                        ToolTip="Предыдущий месяц">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="17.5"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <TextBlock x:Name="txtCurrentMonth" Text="Март 2026" 
                                           FontSize="18" FontWeight="SemiBold" Foreground="#333" 
                                           Width="200" TextAlignment="Center" VerticalAlignment="Center"/>

                                <Button x:Name="btnNextMonth" Content="▶" Width="35" Height="35" 
                                        Background="Transparent" BorderBrush="Transparent" 
                                        FontSize="16" Cursor="Hand" Click="btnNextMonth_Click"
                                        ToolTip="Следующий месяц">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="17.5"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <Button x:Name="btnToday" Content="Сегодня" 
                                        Height="35" Padding="15,0"
                                        Background="#4CAF50" Foreground="White"
                                        BorderBrush="Transparent"
                                        FontSize="12" FontWeight="SemiBold"
                                        Cursor="Hand" Click="btnToday_Click"
                                        Margin="10,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Кнопки управления -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="btnMinimize" Content="─" Width="35" Height="35" 
                                Background="Transparent" BorderBrush="Transparent" 
                                FontSize="18" Cursor="Hand" Click="btnMinimize_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="17.5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="btnClose" Content="✕" Width="35" Height="35" 
                                Background="Transparent" BorderBrush="Transparent" 
                                FontSize="18" Foreground="#E74C3C" Cursor="Hand" Click="btnClose_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="17.5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== ОСНОВНОЙ КОНТЕНТ ==================== -->
            <Grid Grid.Row="1" Margin="25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="350"/>
                </Grid.ColumnDefinitions>

                <!-- ===== ЛЕВАЯ ЧАСТЬ: Календарь ===== -->
                <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок календаря -->
                        <TextBlock Grid.Row="0" Text="Календарь активности" 
                                   FontSize="18" FontWeight="SemiBold" Foreground="#333" 
                                   Margin="0,0,0,20"/>

                        <!-- Дни недели -->
                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="ПН" FontWeight="Bold" Foreground="#999" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="ВТ" FontWeight="Bold" Foreground="#999" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="СР" FontWeight="Bold" Foreground="#999" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="ЧТ" FontWeight="Bold" Foreground="#999" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="ПТ" FontWeight="Bold" Foreground="#999" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="СБ" FontWeight="Bold" Foreground="#999" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="ВС" FontWeight="Bold" Foreground="#999" HorizontalAlignment="Center"/>
                        </Grid>

                        <!-- Сетка календаря -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="CalendarGrid" Margin="0,0,0,10">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0" Content="{Binding Day1}" 
                                                    Height="45" Margin="1"
                                                    Background="{Binding Color1}" 
                                                    Foreground="{Binding TextColor1}"
                                                    BorderBrush="Transparent"
                                                    FontWeight="{Binding FontWeight1}"
                                                    Cursor="Hand"
                                                    Tag="{Binding Date1}"
                                                    Click="DayButton_Click">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>

                                            <Button Grid.Column="1" Content="{Binding Day2}" 
                                                    Height="45" Margin="1"
                                                    Background="{Binding Color2}" 
                                                    Foreground="{Binding TextColor2}"
                                                    BorderBrush="Transparent"
                                                    FontWeight="{Binding FontWeight2}"
                                                    Cursor="Hand"
                                                    Tag="{Binding Date2}"
                                                    Click="DayButton_Click">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>

                                            <Button Grid.Column="2" Content="{Binding Day3}" 
                                                    Height="45" Margin="1"
                                                    Background="{Binding Color3}" 
                                                    Foreground="{Binding TextColor3}"
                                                    BorderBrush="Transparent"
                                                    FontWeight="{Binding FontWeight3}"
                                                    Cursor="Hand"
                                                    Tag="{Binding Date3}"
                                                    Click="DayButton_Click">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>

                                            <Button Grid.Column="3" Content="{Binding Day4}" 
                                                    Height="45" Margin="1"
                                                    Background="{Binding Color4}" 
                                                    Foreground="{Binding TextColor4}"
                                                    BorderBrush="Transparent"
                                                    FontWeight="{Binding FontWeight4}"
                                                    Cursor="Hand"
                                                    Tag="{Binding Date4}"
                                                    Click="DayButton_Click">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>

                                            <Button Grid.Column="4" Content="{Binding Day5}" 
                                                    Height="45" Margin="1"
                                                    Background="{Binding Color5}" 
                                                    Foreground="{Binding TextColor5}"
                                                    BorderBrush="Transparent"
                                                    FontWeight="{Binding FontWeight5}"
                                                    Cursor="Hand"
                                                    Tag="{Binding Date5}"
                                                    Click="DayButton_Click">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>

                                            <Button Grid.Column="5" Content="{Binding Day6}" 
                                                    Height="45" Margin="1"
                                                    Background="{Binding Color6}" 
                                                    Foreground="{Binding TextColor6}"
                                                    BorderBrush="Transparent"
                                                    FontWeight="{Binding FontWeight6}"
                                                    Cursor="Hand"
                                                    Tag="{Binding Date6}"
                                                    Click="DayButton_Click">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>

                                            <Button Grid.Column="6" Content="{Binding Day7}" 
                                                    Height="45" Margin="1"
                                                    Background="{Binding Color7}" 
                                                    Foreground="{Binding TextColor7}"
                                                    BorderBrush="Transparent"
                                                    FontWeight="{Binding FontWeight7}"
                                                    Cursor="Hand"
                                                    Tag="{Binding Date7}"
                                                    Click="DayButton_Click">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Легенда календаря -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                                <Border Width="12" Height="12" Background="#4CAF50" CornerRadius="3" Margin="0,0,5,0"/>
                                <TextBlock Text="Все выполнено" FontSize="10" Foreground="#666"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                                <Border Width="12" Height="12" Background="#F39C12" CornerRadius="3" Margin="0,0,5,0"/>
                                <TextBlock Text="Частично" FontSize="10" Foreground="#666"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="12" Height="12" Background="#E74C3C" CornerRadius="3" Margin="0,0,5,0"/>
                                <TextBlock Text="Не выполнено" FontSize="10" Foreground="#666"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== ПРАВАЯ ЧАСТЬ: Детали выбранного дня ===== -->
                <Border Grid.Column="2" Background="White" CornerRadius="15" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок и выбранная дата -->
                        <TextBlock Grid.Row="0" Text="Детали дня" 
                                   FontSize="18" FontWeight="SemiBold" Foreground="#333" 
                                   Margin="0,0,0,15"/>

                        <Border Grid.Row="1" Background="#F0F0F0" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" x:Name="txtSelectedDateIcon" Text="📅" FontSize="24" Margin="0,0,15,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="txtSelectedDate" Text="19 марта 2026" FontSize="16" FontWeight="SemiBold" Foreground="#333"/>
                                    <TextBlock x:Name="txtSelectedWeekDay" Text="Среда" FontSize="14" Foreground="#666"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Фильтр по привычкам -->
                        <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Фильтр по привычкам" 
                                           FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                           Margin="0,0,0,10"/>

                                <ComboBox Grid.Row="1" x:Name="cmbHistoryHabitFilter" 
                                          Height="35" FontSize="13"
                                          SelectionChanged="cmbHistoryHabitFilter_SelectionChanged">
                                    <ComboBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </ComboBox.Resources>
                                    <ComboBoxItem Content="Все привычки" IsSelected="True" Tag="0"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Список привычек за выбранный день -->
                        <Border Grid.Row="3" Background="#F8F9FA" CornerRadius="10" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Отметки за день" 
                                           FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                           Margin="0,0,0,10"/>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="lstDayHabits">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding BackgroundColor}" 
                                                        CornerRadius="8" Padding="10" 
                                                        Margin="0,0,0,5"
                                                        BorderBrush="{Binding BorderColor}"
                                                        BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="16" Margin="0,0,10,0"/>

                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding HabitName}" 
                                                                       FontSize="14" FontWeight="SemiBold" 
                                                                       Foreground="{Binding TextColor}"/>
                                                            <TextBlock Text="{Binding Description}" 
                                                                       FontSize="11" Foreground="{Binding TextColor}" 
                                                                       Opacity="0.7"
                                                                       Margin="0,2,0,0"/>
                                                        </StackPanel>

                                                        <Border Grid.Column="2" 
                                                                Background="{Binding StatusColor}" 
                                                                CornerRadius="12" Padding="8,3">
                                                            <TextBlock Text="{Binding StatusText}" 
                                                                       FontSize="11" FontWeight="Bold" 
                                                                       Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Кнопка редактирования -->
                        <Button Grid.Row="4" x:Name="btnEditDay" 
                                Content="✏️ Редактировать этот день" 
                                Height="45" Margin="0,15,0,0"
                                Background="#3498DB" Foreground="White"
                                BorderBrush="Transparent"
                                FontSize="14" FontWeight="SemiBold"
                                Cursor="Hand"
                                Click="btnEditDay_Click"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ==================== НИЖНЯЯ ПАНЕЛЬ ==================== -->
            <Border Grid.Row="2" Background="White" CornerRadius="0,0,20,20" Padding="25,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Краткая статистика за месяц -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Статистика месяца: " Foreground="#666" Margin="0,0,5,0"/>
                        <TextBlock x:Name="txtMonthStats" Text="0 выполнено / 0 пропущено / 0 всего" Foreground="#333" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Кнопка закрытия -->
                    <Button Grid.Column="1" x:Name="btnBack" 
                            Content="◀ Закрыть историю" 
                            Height="40" Padding="20,0"
                            Background="Transparent" 
                            BorderBrush="#DDD" 
                            BorderThickness="1.5"
                            Foreground="#666"
                            Cursor="Hand"
                            Click="btnBack_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>