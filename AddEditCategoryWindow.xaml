<Window x:Class="HabitFlow.AddEditCategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HabitFlow"
        mc:Ignorable="d"
        Title="Добавление категории"
        Height="750" Width="710"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded">

    <Border CornerRadius="20" Background="White" Padding="25">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#33000000" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ==================== ЗАГОЛОВОК ==================== -->
            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,20">
                <TextBlock x:Name="txtWindowTitle" 
                           Text="Новая категория" 
                           FontSize="24" 
                           FontWeight="SemiBold" 
                           Foreground="#333"
                           DockPanel.Dock="Left"/>
                <Button x:Name="btnClose" 
                        Content="✕" 
                        Width="35" Height="35"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Foreground="#999"
                        FontSize="18"
                        Cursor="Hand"
                        DockPanel.Dock="Right"
                        Click="btnClose_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="17.5"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="1"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#E74C3C"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </DockPanel>

            <!-- ==================== ФОРМА ==================== -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Название категории (обязательное) -->
                    <TextBlock Text="Название категории *" 
                               FontSize="14" 
                               Foreground="#666" 
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="txtCategoryName" 
                             Height="45" 
                             FontSize="16" 
                             Padding="12,0"
                             BorderBrush="#DDD" 
                             BorderThickness="1"
                             TextChanged="txtCategoryName_TextChanged"
                             MaxLength="100"
                             Margin="0,0,0,15">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- Описание категории -->
                    <TextBlock Text="Описание (необязательно)" 
                               FontSize="14" 
                               Foreground="#666" 
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="txtDescription" 
                             Height="80" 
                             FontSize="14" 
                             Padding="12"
                             BorderBrush="#DDD" 
                             BorderThickness="1"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MaxLength="500"
                             Margin="0,0,0,15">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- Иконка категории -->
                    <TextBlock Text="Иконка категории" 
                               FontSize="14" 
                               Foreground="#666" 
                               Margin="0,0,0,10"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto" 
                                  VerticalScrollBarVisibility="Disabled" 
                                  Height="55" 
                                  Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnIcon1" 
                                    Content="📁" 
                                    Width="50" Height="50" 
                                    FontSize="28" 
                                    Background="Transparent" 
                                    BorderBrush="#DDD" 
                                    BorderThickness="1" 
                                    Margin="0,0,5,0"
                                    Cursor="Hand" 
                                    Click="IconButton_Click" 
                                    Tag="📁"
                                    ToolTip="Папка">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button x:Name="btnIcon2" 
                                    Content="📊" 
                                    Width="50" Height="50" 
                                    FontSize="28" 
                                    Background="Transparent" 
                                    BorderBrush="#DDD" 
                                    BorderThickness="1" 
                                    Margin="0,0,5,0"
                                    Cursor="Hand" 
                                    Click="IconButton_Click" 
                                    Tag="📊"
                                    ToolTip="График">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button x:Name="btnIcon3" 
                                    Content="🏃" 
                                    Width="50" Height="50" 
                                    FontSize="28" 
                                    Background="Transparent" 
                                    BorderBrush="#DDD" 
                                    BorderThickness="1" 
                                    Margin="0,0,5,0"
                                    Cursor="Hand" 
                                    Click="IconButton_Click" 
                                    Tag="🏃"
                                    ToolTip="Спорт">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button x:Name="btnIcon4" 
                                    Content="📚" 
                                    Width="50" Height="50" 
                                    FontSize="28" 
                                    Background="Transparent" 
                                    BorderBrush="#DDD" 
                                    BorderThickness="1" 
                                    Margin="0,0,5,0"
                                    Cursor="Hand" 
                                    Click="IconButton_Click" 
                                    Tag="📚"
                                    ToolTip="Обучение">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button x:Name="btnIcon5" 
                                    Content="💪" 
                                    Width="50" Height="50" 
                                    FontSize="28" 
                                    Background="Transparent" 
                                    BorderBrush="#DDD" 
                                    BorderThickness="1" 
                                    Margin="0,0,5,0"
                                    Cursor="Hand" 
                                    Click="IconButton_Click" 
                                    Tag="💪"
                                    ToolTip="Сила">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button x:Name="btnIcon6" 
                                    Content="🧠" 
                                    Width="50" Height="50" 
                                    FontSize="28" 
                                    Background="Transparent" 
                                    BorderBrush="#DDD" 
                                    BorderThickness="1" 
                                    Margin="0,0,5,0"
                                    Cursor="Hand" 
                                    Click="IconButton_Click" 
                                    Tag="🧠"
                                    ToolTip="Мозг">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button x:Name="btnIcon7" 
                                    Content="💧" 
                                    Width="50" Height="50" 
                                    FontSize="28" 
                                    Background="Transparent" 
                                    BorderBrush="#DDD" 
                                    BorderThickness="1" 
                                    Margin="0,0,5,0"
                                    Cursor="Hand" 
                                    Click="IconButton_Click" 
                                    Tag="💧"
                                    ToolTip="Вода">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button x:Name="btnIcon8" 
                                    Content="🥗" 
                                    Width="50" Height="50" 
                                    FontSize="28" 
                                    Background="Transparent" 
                                    BorderBrush="#DDD" 
                                    BorderThickness="1" 
                                    Margin="0,0,5,0"
                                    Cursor="Hand" 
                                    Click="IconButton_Click" 
                                    Tag="🥗"
                                    ToolTip="Питание">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button x:Name="btnIcon9" 
                                    Content="😴" 
                                    Width="50" Height="50" 
                                    FontSize="28" 
                                    Background="Transparent" 
                                    BorderBrush="#DDD" 
                                    BorderThickness="1" 
                                    Margin="0,0,5,0"
                                    Cursor="Hand" 
                                    Click="IconButton_Click" 
                                    Tag="😴"
                                    ToolTip="Сон">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button x:Name="btnIcon10" 
                                    Content="🎯" 
                                    Width="50" Height="50" 
                                    FontSize="28" 
                                    Background="Transparent" 
                                    BorderBrush="#DDD" 
                                    BorderThickness="1" 
                                    Margin="0,0,5,0"
                                    Cursor="Hand" 
                                    Click="IconButton_Click" 
                                    Tag="🎯"
                                    ToolTip="Цель">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button x:Name="btnIcon11" 
                                    Content="🎨" 
                                    Width="50" Height="50" 
                                    FontSize="28" 
                                    Background="Transparent" 
                                    BorderBrush="#DDD" 
                                    BorderThickness="1" 
                                    Margin="0,0,5,0"
                                    Cursor="Hand" 
                                    Click="IconButton_Click" 
                                    Tag="🎨"
                                    ToolTip="Творчество">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button x:Name="btnIcon12" 
                                    Content="💰" 
                                    Width="50" Height="50" 
                                    FontSize="28" 
                                    Background="Transparent" 
                                    BorderBrush="#DDD" 
                                    BorderThickness="1" 
                                    Margin="0,0,5,0"
                                    Cursor="Hand" 
                                    Click="IconButton_Click" 
                                    Tag="💰"
                                    ToolTip="Финансы">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Цвет категории -->
                    <TextBlock Text="Цвет категории" 
                               FontSize="14" 
                               Foreground="#666" 
                               Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="btnColor1" 
                                Width="40" Height="40" 
                                Background="#4CAF50" 
                                BorderBrush="Transparent" 
                                Margin="2" 
                                Cursor="Hand" 
                                Click="ColorButton_Click" 
                                Tag="#4CAF50"
                                ToolTip="Зеленый">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Grid.Column="1" x:Name="btnColor2" 
                                Width="40" Height="40" 
                                Background="#3498DB" 
                                BorderBrush="Transparent" 
                                Margin="2" 
                                Cursor="Hand" 
                                Click="ColorButton_Click" 
                                Tag="#3498DB"
                                ToolTip="Синий">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Grid.Column="2" x:Name="btnColor3" 
                                Width="40" Height="40" 
                                Background="#E74C3C" 
                                BorderBrush="Transparent" 
                                Margin="2" 
                                Cursor="Hand" 
                                Click="ColorButton_Click" 
                                Tag="#E74C3C"
                                ToolTip="Красный">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Grid.Column="3" x:Name="btnColor4" 
                                Width="40" Height="40" 
                                Background="#F39C12" 
                                BorderBrush="Transparent" 
                                Margin="2" 
                                Cursor="Hand" 
                                Click="ColorButton_Click" 
                                Tag="#F39C12"
                                ToolTip="Оранжевый">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Grid.Column="4" x:Name="btnColor5" 
                                Width="40" Height="40" 
                                Background="#9B59B6" 
                                BorderBrush="Transparent" 
                                Margin="2" 
                                Cursor="Hand" 
                                Click="ColorButton_Click" 
                                Tag="#9B59B6"
                                ToolTip="Фиолетовый">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Grid.Column="5" x:Name="btnColor6" 
                                Width="40" Height="40" 
                                Background="#1ABC9C" 
                                BorderBrush="Transparent" 
                                Margin="2" 
                                Cursor="Hand" 
                                Click="ColorButton_Click" 
                                Tag="#1ABC9C"
                                ToolTip="Бирюзовый">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>

                    <!-- Порядок отображения -->
                    <TextBlock Text="Порядок отображения" 
                               FontSize="14" 
                               Foreground="#666" 
                               Margin="0,0,0,5"/>

                    <ComboBox x:Name="cmbDisplayOrder" 
                              Height="40" 
                              FontSize="14"
                              Margin="0,0,0,10">
                        <ComboBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </ComboBox.Resources>
                        <ComboBoxItem Content="Первый (в начале списка)" Tag="0" IsSelected="True"/>
                        <ComboBoxItem Content="Второй" Tag="1"/>
                        <ComboBoxItem Content="Третий" Tag="2"/>
                        <ComboBoxItem Content="Четвертый" Tag="3"/>
                        <ComboBoxItem Content="Пятый" Tag="4"/>
                        <ComboBoxItem Content="Шестой" Tag="5"/>
                        <ComboBoxItem Content="Седьмой" Tag="6"/>
                        <ComboBoxItem Content="Восьмой" Tag="7"/>
                        <ComboBoxItem Content="Девятый" Tag="8"/>
                        <ComboBoxItem Content="Десятый" Tag="9"/>
                    </ComboBox>

                    <!-- Предпросмотр категории -->
                    <Border Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,5,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Предпросмотр" 
                                       FontSize="12" Foreground="#999" 
                                       Margin="0,0,0,10"/>

                            <Border Grid.Row="1" 
                                    Background="{Binding ElementName=btnColor1, Path=Background}"
                                    CornerRadius="8" 
                                    Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" x:Name="previewIcon" 
                                               Text="📁" FontSize="20" 
                                               Margin="0,0,10,0" Foreground="White"/>

                                    <TextBlock Grid.Column="1" x:Name="previewName" 
                                               Text="Название категории" 
                                               FontSize="14" FontWeight="SemiBold" 
                                               Foreground="White" 
                                               VerticalAlignment="Center"/>

                                    <Border Grid.Column="2" 
                                            Background="#80FFFFFF" 
                                            CornerRadius="10" 
                                            Padding="6,2">
                                        <TextBlock x:Name="previewCount" 
                                                   Text="12" 
                                                   FontSize="11" FontWeight="Bold" 
                                                   Foreground="White"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ==================== КНОПКИ ==================== -->
            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" 
                        x:Name="btnCancel" 
                        Content="Отмена" 
                        Height="45" 
                        Margin="0,0,5,0"
                        Background="Transparent" 
                        BorderBrush="#DDD" 
                        BorderThickness="1.5"
                        Foreground="#666"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="btnCancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="1"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F5F5F5"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="1" 
                        x:Name="btnSave" 
                        Content="Сохранить" 
                        Height="45" 
                        Margin="5,0,0,0"
                        Background="#4CAF50" 
                        BorderBrush="Transparent"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        IsEnabled="False"
                        Click="btnSave_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="1"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#CCCCCC"/>
                                    <Setter Property="Foreground" Value="#999999"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Подсказка об обязательных полях -->
            <TextBlock Grid.Row="2" 
                       Text="* обязательное поле" 
                       FontSize="11" 
                       Foreground="#999" 
                       VerticalAlignment="Bottom" 
                       HorizontalAlignment="Left"
                       Margin="0,0,0,55"/>
        </Grid>
    </Border>
</Window>