<Window x:Class="HabitFlow.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HabitFlow"
        mc:Ignorable="d"
        Title="О программе"
        Height="650" Width="550"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded">

    <Border CornerRadius="20" Background="White" Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="0" Color="#33000000" Opacity="0.4"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="200"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- ==================== ВЕРХНЯЯ ПАНЕЛЬ С ГРАДИЕНТОМ ==================== -->
            <Border Grid.Row="0" CornerRadius="20,20,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4CAF50" Offset="0"/>
                        <GradientStop Color="#2E7D32" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <!-- Декоративные элементы -->
                    <Ellipse Width="300" Height="300" Fill="#20FFFFFF" 
                             HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-100,-100,0,0"/>
                    <Ellipse Width="200" Height="200" Fill="#15FFFFFF" 
                             HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-50,-50"/>

                    <!-- Кнопка закрытия -->
                    <Button x:Name="btnClose" 
                            Content="✕" 
                            Width="40" Height="40"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Foreground="White"
                            FontSize="20"
                            Cursor="Hand"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="15"
                            Click="btnClose_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="20"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="0.8"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Setter Property="Background" Value="#30FFFFFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Логотип и название -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Width="80" Height="80" Background="White" CornerRadius="40" 
                                HorizontalAlignment="Center" Margin="0,0,0,15">
                            <TextBlock Text="📊" FontSize="48" Foreground="#4CAF50" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="HabitFlow" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="трекер привычек" FontSize="14" Foreground="#E0E0E0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== ОСНОВНОЙ КОНТЕНТ ==================== -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="30,20,30,20">

                    <!-- Версия приложения -->
                    <Border Background="#F0F0F0" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="📌" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Версия приложения" FontSize="12" Foreground="#999"/>
                                <TextBlock x:Name="txtVersion" Text="1.0.0.0" FontSize="18" FontWeight="SemiBold" Foreground="#333"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Информация о разработчике -->
                    <Border Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="👨‍💻 Разработчик" 
                                       FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                       Margin="0,0,0,10"/>

                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Имя:" Foreground="#666" FontSize="13"/>
                                <TextBlock Grid.Column="1" x:Name="txtDeveloperName" Text="Иван Петров" Foreground="#333" FontSize="13" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Email:" Foreground="#666" FontSize="13"/>
                                <TextBlock Grid.Column="1" x:Name="txtDeveloperEmail" Text="ivan@example.com" Foreground="#333" FontSize="13"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Используемые технологии -->
                    <Border Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="⚙️ Используемые технологии" 
                                       FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                       Margin="0,0,0,10"/>

                            <WrapPanel Grid.Row="1">
                                <Border Background="#4CAF5020" CornerRadius="15" Padding="8,4" Margin="0,0,8,8">
                                    <TextBlock Text=".NET Framework 4.7.2" FontSize="11" Foreground="#4CAF50"/>
                                </Border>
                                <Border Background="#3498DB20" CornerRadius="15" Padding="8,4" Margin="0,0,8,8">
                                    <TextBlock Text="WPF" FontSize="11" Foreground="#3498DB"/>
                                </Border>
                                <Border Background="#F39C1220" CornerRadius="15" Padding="8,4" Margin="0,0,8,8">
                                    <TextBlock Text="Entity Framework 6.2" FontSize="11" Foreground="#F39C12"/>
                                </Border>
                                <Border Background="#E74C3C20" CornerRadius="15" Padding="8,4" Margin="0,0,8,8">
                                    <TextBlock Text="SQL Server" FontSize="11" Foreground="#E74C3C"/>
                                </Border>
                                <Border Background="#9B59B620" CornerRadius="15" Padding="8,4" Margin="0,0,8,8">
                                    <TextBlock Text="LiveCharts" FontSize="11" Foreground="#9B59B6"/>
                                </Border>
                                <Border Background="#1ABC9C20" CornerRadius="15" Padding="8,4" Margin="0,0,8,8">
                                    <TextBlock Text="Newtonsoft.Json" FontSize="11" Foreground="#1ABC9C"/>
                                </Border>
                                <Border Background="#E67E2220" CornerRadius="15" Padding="8,4" Margin="0,0,8,8">
                                    <TextBlock Text="MVVM" FontSize="11" Foreground="#E67E22"/>
                                </Border>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <!-- Особенности приложения -->
                    <Border Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="✨ Особенности" 
                                       FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                       Margin="0,0,0,10"/>

                            <StackPanel Grid.Row="1">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="✅" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="Отслеживание привычек по дням" FontSize="12" Foreground="#666"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="✅" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="Три статуса выполнения" FontSize="12" Foreground="#666"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="✅" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="Статистика и графики прогресса" FontSize="12" Foreground="#666"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="✅" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="Система достижений и серий" FontSize="12" Foreground="#666"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="✅" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="Экспорт и импорт данных" FontSize="12" Foreground="#666"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="✅" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="Кастомизация интерфейса" FontSize="12" Foreground="#666"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Ссылки и контакты -->
                    <Border Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="🔗 Ссылки" 
                                       FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                       Margin="0,0,0,10"/>

                            <StackPanel Grid.Row="1">
                                <Button x:Name="btnWebsite" 
                                        Content="🌐 Официальный сайт" 
                                        Background="Transparent" 
                                        BorderBrush="Transparent"
                                        Foreground="#3498DB"
                                        HorizontalContentAlignment="Left"
                                        Cursor="Hand"
                                        Margin="0,0,0,5"
                                        Click="btnWebsite_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Opacity" Value="0.8"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                    <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button x:Name="btnGitHub" 
                                        Content="🐱 GitHub" 
                                        Background="Transparent" 
                                        BorderBrush="Transparent"
                                        Foreground="#3498DB"
                                        HorizontalContentAlignment="Left"
                                        Cursor="Hand"
                                        Margin="0,0,0,5"
                                        Click="btnGitHub_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Opacity" Value="0.8"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                    <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button x:Name="btnSupport" 
                                        Content="📧 Поддержка" 
                                        Background="Transparent" 
                                        BorderBrush="Transparent"
                                        Foreground="#3498DB"
                                        HorizontalContentAlignment="Left"
                                        Cursor="Hand"
                                        Margin="0,0,0,5"
                                        Click="btnSupport_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Opacity" Value="0.8"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                    <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Лицензия -->
                    <Border Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="📄 Лицензия" 
                                       FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                       Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="1" x:Name="txtLicense" 
                                       Text="Данное программное обеспечение распространяется под лицензией MIT. Вы можете свободно использовать, модифицировать и распространять его при условии сохранения уведомления об авторских правах."
                                       FontSize="11" Foreground="#666" TextWrapping="Wrap"/>
                        </Grid>
                    </Border>

                    <!-- Благодарности -->
                    <Border Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="🙏 Благодарности" 
                                       FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                       Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="1" x:Name="txtThanks" 
                                       Text="Всем пользователям, которые каждый день работают над собой и своими привычками. Спасибо, что выбираете HabitFlow!"
                                       FontSize="11" Foreground="#666" TextWrapping="Wrap" FontStyle="Italic"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ==================== НИЖНЯЯ ПАНЕЛЬ ==================== -->
            <Border Grid.Row="2" Background="#F0F0F0" CornerRadius="0,0,20,20" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Копирайт -->
                    <TextBlock Grid.Column="0" x:Name="txtCopyright" 
                               Text="© 2026 HabitFlow. Все права защищены." 
                               Foreground="#999" FontSize="11" VerticalAlignment="Center"/>

                    <!-- Кнопка закрытия -->
                    <Button Grid.Column="1" x:Name="btnOk" 
                            Content="OK" 
                            Height="40" Width="100"
                            Background="#4CAF50" Foreground="White"
                            BorderBrush="Transparent"
                            FontSize="14" FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="btnOk_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>