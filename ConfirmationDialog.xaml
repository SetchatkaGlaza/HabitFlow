<Window x:Class="HabitFlow.ConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HabitFlow"
        mc:Ignorable="d"
        Title="Подтверждение действия"
        Height="Auto" Width="500"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded">

    <Border CornerRadius="20" Background="White" Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="0" Color="#33000000" Opacity="0.4"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ==================== ВЕРХНЯЯ ПАНЕЛЬ С ИКОНКОЙ ==================== -->
            <Border Grid.Row="0" x:Name="HeaderBorder" Height="100" CornerRadius="20,20,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop x:Name="GradientStart" Color="#4CAF50" Offset="0"/>
                        <GradientStop x:Name="GradientEnd" Color="#45A049" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <!-- Иконка -->
                    <TextBlock x:Name="IconText" Text="❓" 
                               FontSize="48" Foreground="White" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextOptions.TextRenderingMode="ClearType"
                               TextOptions.TextFormattingMode="Ideal"/>

                    <!-- Кнопка закрытия (только для информационных окон) -->
                    <Button x:Name="btnCloseIcon" 
                            Content="✕" 
                            Width="35" Height="35"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Foreground="#FFFFFF"
                            FontSize="18"
                            Cursor="Hand"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="10"
                            Click="btnClose_Click"
                            Visibility="Collapsed">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="17.5"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="0.7"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- ==================== ОСНОВНОЙ КОНТЕНТ ==================== -->
            <StackPanel Grid.Row="1" Margin="30,25,30,20">

                <!-- Заголовок -->
                <TextBlock x:Name="TitleText" 
                           Text="Подтверждение действия" 
                           FontSize="20" FontWeight="SemiBold" 
                           Foreground="#333" 
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,15"/>

                <!-- Сообщение -->
                <TextBlock x:Name="MessageText" 
                           Text="Вы уверены, что хотите выполнить это действие?" 
                           FontSize="14" 
                           Foreground="#666" 
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

                <!-- Дополнительная информация (опционально) -->
                <Border x:Name="InfoBorder" 
                        Background="#F8F9FA" 
                        CornerRadius="10" 
                        Padding="15" 
                        Margin="0,0,0,20"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        Visibility="Collapsed">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" x:Name="InfoIcon" Text="ℹ️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top"/>
                        <TextBlock Grid.Column="1" x:Name="InfoText" 
                                   Text="Дополнительная информация" 
                                   FontSize="12" Foreground="#666" 
                                   TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <!-- Детали (например, список удаляемых элементов) -->
                <Border x:Name="DetailsBorder" 
                        Background="#F0F0F0" 
                        CornerRadius="8" 
                        Padding="12" 
                        Margin="0,0,0,20"
                        MaxHeight="200"
                        Visibility="Collapsed">

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="DetailsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" 
                                               FontSize="12" Foreground="#333" 
                                               Margin="0,2,0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Чекбокс "Больше не спрашивать" -->
                <CheckBox x:Name="DontAskAgainCheckBox" 
                          Content="Больше не спрашивать для этого действия" 
                          FontSize="12" Foreground="#666"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,15"
                          Visibility="Collapsed"/>

                <!-- Поле для ввода (для подтверждения паролем или текстом) -->
                <Border x:Name="InputBorder" 
                        Background="#F8F9FA" 
                        CornerRadius="8" 
                        Padding="12" 
                        Margin="0,0,0,20"
                        Visibility="Collapsed">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" x:Name="InputLabel" 
                                   Text="Введите текст для подтверждения:" 
                                   FontSize="12" Foreground="#666" 
                                   Margin="0,0,0,8"/>

                        <TextBox Grid.Row="1" x:Name="InputTextBox" 
                                 Height="35" Padding="10,0"
                                 BorderBrush="#DDD" BorderThickness="1"
                                 TextChanged="InputTextBox_TextChanged">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>

                        <PasswordBox Grid.Row="1" x:Name="InputPasswordBox" 
                                     Height="35" Padding="10,0"
                                     BorderBrush="#DDD" BorderThickness="1"
                                     PasswordChanged="InputPasswordBox_PasswordChanged"
                                     Visibility="Collapsed">
                            <PasswordBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </PasswordBox.Resources>
                        </PasswordBox>
                    </Grid>
                </Border>

                <!-- Прогресс (для длительных операций) -->
                <Border x:Name="ProgressBorder" 
                        Background="#F8F9FA" 
                        CornerRadius="8" 
                        Padding="15" 
                        Margin="0,0,0,20"
                        Visibility="Collapsed">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" x:Name="ProgressText" 
                                   Text="Выполняется операция..." 
                                   FontSize="12" Foreground="#666" 
                                   Margin="0,0,0,10"
                                   HorizontalAlignment="Center"/>

                        <ProgressBar Grid.Row="1" x:Name="ProgressBar" 
                                     Height="6" 
                                     Minimum="0" Maximum="100" 
                                     Value="0" 
                                     Foreground="#4CAF50" 
                                     Background="#EEE"
                                     IsIndeterminate="True"/>
                    </Grid>
                </Border>

                <!-- Предупреждение (красная рамка) -->
                <Border x:Name="WarningBorder" 
                        Background="#FFEBEE" 
                        CornerRadius="8" 
                        Padding="12" 
                        Margin="0,0,0,20"
                        BorderBrush="#E74C3C"
                        BorderThickness="1"
                        Visibility="Collapsed">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="⚠️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top"/>
                        <TextBlock Grid.Column="1" x:Name="WarningText" 
                                   Text="Это действие необратимо! Будьте внимательны." 
                                   FontSize="12" Foreground="#E74C3C" 
                                   TextWrapping="Wrap"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ==================== КНОПКИ ==================== -->
            <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="0,0,20,20" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Кнопка отмены / нет -->
                    <Button Grid.Column="0" x:Name="CancelButton" 
                            Content="Отмена" 
                            Height="45"
                            Background="Transparent" 
                            BorderBrush="#DDD" 
                            BorderThickness="1.5"
                            Foreground="#666"
                            FontSize="14" FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="CancelButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Кнопка подтверждения / да / продолжить -->
                    <Button Grid.Column="2" x:Name="ConfirmButton" 
                            Content="Подтвердить" 
                            Height="45"
                            Background="#4CAF50" 
                            BorderBrush="Transparent"
                            Foreground="White"
                            FontSize="14" FontWeight="SemiBold"
                            Cursor="Hand"
                            IsEnabled="True"
                            Click="ConfirmButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#CCCCCC"/>
                                        <Setter Property="Foreground" Value="#999999"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Полоска для перетаскивания (маленькая) -->
            <Rectangle Grid.Row="0" Height="5" Width="50" 
                       Fill="#80FFFFFF" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Top" 
                       Margin="0,10,0,0"
                       RadiusX="2.5" RadiusY="2.5"
                       IsHitTestVisible="False"/>
        </Grid>
    </Border>
</Window>