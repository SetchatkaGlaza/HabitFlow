<Window x:Class="HabitFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HabitFlow"
        mc:Ignorable="d"
        Title="HabitFlow - Трекер привычек"
        Height="850" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded"
        Closed="Window_Closed">

    <Border CornerRadius="20" Background="#F5F7FA" Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#33000000" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- ==================== ВЕРХНЯЯ ПАНЕЛЬ ==================== -->
            <Border Grid.Row="0" Background="White" CornerRadius="20,20,0,0" Padding="20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Логотип и название -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📊" FontSize="28" Margin="0,0,10,0"/>
                        <TextBlock Text="HabitFlow" FontSize="24" FontWeight="Bold" Foreground="#4CAF50"/>
                    </StackPanel>

                    <!-- Информация о пользователе и дате -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Background="#F0F0F0" CornerRadius="15" Padding="15,5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="txtCurrentDate" Text="Сегодня: " FontSize="14" Foreground="#666"/>
                                <TextBlock x:Name="txtCurrentDateValue" Text="01.01.2024" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="5,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Профиль и управление окном -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- Кнопки навигации -->
                        <Button x:Name="btnStatistics" 
                                Content="📊" 
                                Width="40" Height="40"
                                Background="#3498DB" 
                                Foreground="White"
                                BorderBrush="Transparent"
                                FontSize="20"
                                Cursor="Hand"
                                Margin="0,0,5,0"
                                ToolTip="Статистика"
                                Click="btnStatistics_Click"/>

                        <Button x:Name="btnHistory" 
                                Content="📜" 
                                Width="40" Height="40"
                                Background="#9B59B6" 
                                Foreground="White"
                                BorderBrush="Transparent"
                                FontSize="20"
                                Cursor="Hand"
                                Margin="5"
                                ToolTip="История"
                                Click="btnHistory_Click"/>

                        <Button x:Name="btnAchievements" 
                                Content="🏆" 
                                Width="40" Height="40"
                                Background="#FFD700" 
                                Foreground="White"
                                BorderBrush="Transparent"
                                FontSize="20"
                                Cursor="Hand"
                                Margin="5"
                                ToolTip="Достижения"
                                Click="btnAchievements_Click"/>

                        <Button x:Name="btnCategories" 
                                Content="📁" 
                                Width="40" Height="40"
                                Background="#E67E22" 
                                Foreground="White"
                                BorderBrush="Transparent"
                                FontSize="20"
                                Cursor="Hand"
                                Margin="5"
                                ToolTip="Категории"
                                Click="btnCategories_Click"/>

                        <Button x:Name="btnImportExport" 
                                Content="📦" 
                                Width="40" Height="40"
                                Background="#1ABC9C" 
                                Foreground="White"
                                BorderBrush="Transparent"
                                FontSize="20"
                                Cursor="Hand"
                                Margin="5"
                                ToolTip="Импорт/Экспорт"
                                Click="btnImportExport_Click"/>

                        <Button x:Name="btnSettings" 
                                Content="⚙️" 
                                Width="40" Height="40"
                                Background="#95A5A6" 
                                Foreground="White"
                                BorderBrush="Transparent"
                                FontSize="20"
                                Cursor="Hand"
                                Margin="5"
                                ToolTip="Настройки"
                                Click="btnSettings_Click"/>

                        <Button x:Name="btnAbout" 
                                Content="ℹ️" 
                                Width="40" Height="40"
                                Background="#34495E" 
                                Foreground="White"
                                BorderBrush="Transparent"
                                FontSize="20"
                                Cursor="Hand"
                                Margin="5,5,20,5"
                                ToolTip="О программе"
                                Click="btnAbout_Click"/>

                        <!-- Аватар и имя пользователя -->
                        <Border Background="#4CAF50" CornerRadius="20" Padding="10,5" Margin="0,0,20,0" 
                                Cursor="Hand" MouseLeftButtonDown="UserProfile_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👤" FontSize="14" Margin="0,0,5,0"/>
                                <TextBlock x:Name="txtUserName" Text="Пользователь" Foreground="White" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <!-- Кнопки управления окном -->
                        <Button x:Name="btnMinimize" Content="─" Width="30" Height="30" 
                                Background="Transparent" BorderBrush="Transparent" 
                                FontSize="16" Cursor="Hand" Click="btnMinimize_Click"
                                ToolTip="Свернуть"/>
                        <Button x:Name="btnMaximize" Content="□" Width="30" Height="30" 
                                Background="Transparent" BorderBrush="Transparent" 
                                FontSize="16" Cursor="Hand" Click="btnMaximize_Click"
                                ToolTip="Развернуть"/>
                        <Button x:Name="btnClose" Content="✕" Width="30" Height="30" 
                                Background="Transparent" BorderBrush="Transparent" 
                                FontSize="16" Foreground="#E74C3C" Cursor="Hand" Click="btnClose_Click"
                                ToolTip="Закрыть"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== ОСНОВНОЙ КОНТЕНТ ==================== -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="350"/>
                </Grid.ColumnDefinitions>

                <!-- ЛЕВАЯ ЧАСТЬ: Трекер привычек -->
                <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="20" Margin="0,0,10,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок и кнопка добавления -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Мои привычки на эту неделю" 
                                       FontSize="18" FontWeight="SemiBold" Foreground="#333"/>

                            <Button Grid.Column="1" x:Name="btnAddHabit" 
                                    Content="➕ Добавить привычку" 
                                    Height="40" Padding="15,0"
                                    Background="#4CAF50" Foreground="White"
                                    BorderBrush="Transparent" 
                                    Cursor="Hand" FontSize="14" FontWeight="SemiBold"
                                    Click="btnAddHabit_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <!-- Фильтр по категориям -->
                        <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="8" Padding="10" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Категория:" FontSize="12" Foreground="#666" 
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>

                                <ComboBox Grid.Column="1" x:Name="cmbCategoryFilter" 
                                          Height="30" FontSize="12"
                                          SelectionChanged="cmbCategoryFilter_SelectionChanged">
                                    <ComboBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </ComboBox.Resources>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Заголовки дней недели -->
                        <ItemsControl Grid.Row="2" x:Name="weekDayHeaders" Margin="150,0,0,10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="80" Margin="2,0" Background="#F0F0F0" CornerRadius="8" Padding="10,5">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding DayName}" FontSize="14" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding DayNumber}" FontSize="20" FontWeight="Bold" Foreground="#333" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Список привычек с отметками -->
                        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="habitsListView">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F8F9FA" CornerRadius="10" Margin="0,0,0,10" Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Информация о привычке -->
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding IconEmoji}" FontSize="18" Margin="0,0,5,0"/>
                                                        <TextBlock Text="{Binding HabitName}" FontSize="16" FontWeight="SemiBold" Foreground="#333"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                        <Border Background="#4CAF5020" CornerRadius="12" Padding="8,2">
                                                            <TextBlock Text="{Binding CurrentStreak, StringFormat='🔥 {0} дней'}" FontSize="11" Foreground="#4CAF50"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding MaxStreak, StringFormat='Рекорд: {0}'}" FontSize="11" Foreground="#999" Margin="10,0,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Отметки по дням -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <ItemsControl ItemsSource="{Binding WeekRecords}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Button Width="80" Height="70" Margin="2,0"
                                                                        Background="Transparent" BorderBrush="#E0E0E0" BorderThickness="1"
                                                                        Cursor="Hand" Tag="{Binding}"
                                                                        Click="DayButton_Click">
                                                                    <Button.Resources>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="CornerRadius" Value="8"/>
                                                                        </Style>
                                                                    </Button.Resources>
                                                                    <Grid>
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="*"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                        </Grid.RowDefinitions>

                                                                        <TextBlock Grid.Row="0" Text="{Binding DisplaySymbol}" 
                                                                                   FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                                        <Border Grid.Row="1" 
                                                                                Background="{Binding DayStatusColor}" 
                                                                                Height="3" 
                                                                                CornerRadius="0,0,8,8"
                                                                                VerticalAlignment="Bottom"/>
                                                                    </Grid>
                                                                    <Button.Style>
                                                                        <Style TargetType="Button">
                                                                            <Setter Property="Opacity" Value="1"/>
                                                                            <Style.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter Property="Background" Value="#F0F0F0"/>
                                                                                </Trigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <!-- Кнопки управления привычкой -->
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button x:Name="btnEditHabit" 
                                                            Content="✏️" 
                                                            Width="35" Height="35"
                                                            Background="Transparent" BorderBrush="Transparent"
                                                            FontSize="16" Cursor="Hand"
                                                            Tag="{Binding HabitId}"
                                                            Click="btnEditHabit_Click"
                                                            ToolTip="Редактировать">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="8"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>

                                                    <Button x:Name="btnDeleteHabit" 
                                                            Content="🗑️" 
                                                            Width="35" Height="35"
                                                            Background="Transparent" BorderBrush="Transparent"
                                                            FontSize="16" Cursor="Hand"
                                                            Tag="{Binding HabitId}"
                                                            Click="btnDeleteHabit_Click"
                                                            ToolTip="Удалить"
                                                            Margin="5,0,0,0">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="8"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ПРАВАЯ ЧАСТЬ: Аналитика и статистика -->
                <Border Grid.Column="1" Background="White" CornerRadius="15" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1A000000" Opacity="0.1"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок -->
                        <TextBlock Grid.Row="0" Text="Статистика прогресса" FontSize="18" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,20"/>

                        <!-- Общая статистика -->
                        <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Всего привычек" FontSize="12" Foreground="#999"/>
                                    <TextBlock x:Name="txtTotalHabits" Text="0" FontSize="28" FontWeight="Bold" Foreground="#333"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Выполнено сегодня" FontSize="12" Foreground="#999"/>
                                    <TextBlock x:Name="txtCompletedToday" Text="0" FontSize="28" FontWeight="Bold" Foreground="#4CAF50"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Выбор привычки для детальной статистики -->
                        <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Детальная статистика" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>

                                <ComboBox Grid.Row="1" x:Name="cmbHabitStats" 
                                          Height="40" 
                                          DisplayMemberPath="HabitName"
                                          SelectedValuePath="HabitId"
                                          SelectionChanged="cmbHabitStats_SelectionChanged">
                                    <ComboBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </ComboBox.Resources>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Детальная статистика выбранной привычки -->
                        <Border Grid.Row="3" Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Показатели" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,15"/>

                                <Grid Grid.Row="1" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Текущая серия" FontSize="11" Foreground="#999"/>
                                        <TextBlock x:Name="txtCurrentStreakDetail" Text="0" FontSize="18" FontWeight="Bold" Foreground="#4CAF50"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Макс. серия" FontSize="11" Foreground="#999"/>
                                        <TextBlock x:Name="txtMaxStreakDetail" Text="0" FontSize="18" FontWeight="Bold" Foreground="#E67E22"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="2" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="За неделю" FontSize="11" Foreground="#999"/>
                                        <TextBlock x:Name="txtWeeklyProgress" Text="0%" FontSize="18" FontWeight="Bold" Foreground="#3498DB"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="За месяц" FontSize="11" Foreground="#999"/>
                                        <TextBlock x:Name="txtMonthlyProgress" Text="0%" FontSize="18" FontWeight="Bold" Foreground="#9B59B6"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Прогресс-бар месяца -->
                                <StackPanel Grid.Row="3">
                                    <Grid Margin="0,10,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Прогресс месяца" FontSize="11" Foreground="#999"/>
                                        <TextBlock Grid.Column="1" x:Name="txtMonthlyPercent" Text="0%" FontSize="11" FontWeight="SemiBold" Foreground="#333"/>
                                    </Grid>
                                    <Border Height="8" Background="#EEE" CornerRadius="4">
                                        <Border x:Name="progressMonthlyFill" Width="0" Height="8" Background="#9B59B6" CornerRadius="4" HorizontalAlignment="Left"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- График (заглушка для будущей реализации) -->
                        <Border Grid.Row="4" Background="#F8F9FA" CornerRadius="10" Padding="15">
                            <Grid>
                                <TextBlock Text="График выполнения" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>
                                <Border Background="#E0E0E0" CornerRadius="8" Height="150" Margin="0,30,0,0">
                                    <TextBlock Text="Здесь будет график" Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ==================== НИЖНЯЯ ПАНЕЛЬ ==================== -->
            <Border Grid.Row="2" Background="White" CornerRadius="0,0,20,20" Padding="20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Мотивационное сообщение -->
                    <TextBlock Grid.Column="0" x:Name="txtMotivationMessage" 
                               Text="Маленькие шаги каждый день приводят к большим результатам! 🌟" 
                               Foreground="#666" VerticalAlignment="Center"/>

                    <!-- Кнопка информации о программе -->
                    <Button Grid.Column="1" x:Name="btnAboutBottom" 
                            Content="ℹ️ О программе" 
                            Height="35" Padding="10,0"
                            Background="Transparent" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="1"
                            Cursor="Hand"
                            FontSize="11"
                            Click="btnAbout_Click"/>

                    <!-- Кнопка выхода -->
                    <Button Grid.Column="3" x:Name="btnLogout" 
                            Content="🚪 Выйти" 
                            Height="35" Padding="15,0"
                            Background="Transparent" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="1"
                            Cursor="Hand"
                            Click="btnLogout_Click"/>
                </Grid>
            </Border>

            <!-- Gripper для изменения размера окна -->
            <Grid Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="20" Height="20">
                <Path Data="M0,20 L20,0 M5,20 L20,5 M10,20 L20,10 M15,20 L20,15" 
                      Stroke="#CCC" StrokeThickness="1.5" Stretch="None"/>
            </Grid>
        </Grid>
    </Border>
</Window>