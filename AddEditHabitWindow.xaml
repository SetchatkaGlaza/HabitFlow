<Window x:Class="HabitFlow.AddEditHabitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HabitFlow"
        mc:Ignorable="d"
        Title="Добавление привычки"
        Height="750" Width="550"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="20" Background="White" Padding="25">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#33000000" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Шапка с заголовком и кнопкой закрытия -->
            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,20">
                <TextBlock x:Name="txtWindowTitle" 
                           Text="Новая привычка" 
                           FontSize="24" 
                           FontWeight="SemiBold" 
                           Foreground="#333"
                           DockPanel.Dock="Left"/>
                <Button x:Name="btnClose" 
                        Content="✕" 
                        Width="35" 
                        Height="35"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Foreground="#999"
                        FontSize="18"
                        Cursor="Hand"
                        DockPanel.Dock="Right"
                        Click="btnClose_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="17.5"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="1"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#E74C3C"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </DockPanel>

            <!-- Форма -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- Название привычки -->
                    <TextBlock Text="Название привычки *" 
                               FontSize="14" 
                               Foreground="#666" 
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="txtHabitName" 
                             Height="45" 
                             FontSize="16" 
                             Padding="12,0"
                             BorderBrush="#DDD" 
                             BorderThickness="1"
                             TextChanged="txtHabitName_TextChanged"
                             MaxLength="100"
                             Margin="0,0,0,15">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- Описание привычки -->
                    <TextBlock Text="Описание (необязательно)" 
                               FontSize="14" 
                               Foreground="#666" 
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="txtDescription" 
                             Height="100" 
                             FontSize="14" 
                             Padding="12"
                             BorderBrush="#DDD" 
                             BorderThickness="1"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MaxLength="500"
                             Margin="0,0,0,15">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- Иконка (выбор эмодзи) -->
                    <TextBlock Text="Иконка (выберите эмодзи)" 
                               FontSize="14" 
                               Foreground="#666" 
                               Margin="0,0,0,10"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Height="50" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnEmoji1" Content="🏃" Width="45" Height="45" FontSize="24" 
                                    Background="Transparent" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,5,0"
                                    Cursor="Hand" Click="EmojiButton_Click" Tag="🏃">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button x:Name="btnEmoji2" Content="📚" Width="45" Height="45" FontSize="24" 
                                    Background="Transparent" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,5,0"
                                    Cursor="Hand" Click="EmojiButton_Click" Tag="📚">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button x:Name="btnEmoji3" Content="💧" Width="45" Height="45" FontSize="24" 
                                    Background="Transparent" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,5,0"
                                    Cursor="Hand" Click="EmojiButton_Click" Tag="💧">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button x:Name="btnEmoji4" Content="😴" Width="45" Height="45" FontSize="24" 
                                    Background="Transparent" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,5,0"
                                    Cursor="Hand" Click="EmojiButton_Click" Tag="😴">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button x:Name="btnEmoji5" Content="🥗" Width="45" Height="45" FontSize="24" 
                                    Background="Transparent" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,5,0"
                                    Cursor="Hand" Click="EmojiButton_Click" Tag="🥗">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button x:Name="btnEmoji6" Content="💪" Width="45" Height="45" FontSize="24" 
                                    Background="Transparent" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,5,0"
                                    Cursor="Hand" Click="EmojiButton_Click" Tag="💪">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button x:Name="btnEmoji7" Content="🧘" Width="45" Height="45" FontSize="24" 
                                    Background="Transparent" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,5,0"
                                    Cursor="Hand" Click="EmojiButton_Click" Tag="🧘">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button x:Name="btnEmoji8" Content="📝" Width="45" Height="45" FontSize="24" 
                                    Background="Transparent" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,5,0"
                                    Cursor="Hand" Click="EmojiButton_Click" Tag="📝">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button x:Name="btnEmoji9" Content="🎯" Width="45" Height="45" FontSize="24" 
                                    Background="Transparent" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,5,0"
                                    Cursor="Hand" Click="EmojiButton_Click" Tag="🎯">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button x:Name="btnEmoji10" Content="🎨" Width="45" Height="45" FontSize="24" 
                                    Background="Transparent" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,5,0"
                                    Cursor="Hand" Click="EmojiButton_Click" Tag="🎨">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Выбор цвета -->
                    <TextBlock Text="Цвет (необязательно)" 
                               FontSize="14" 
                               Foreground="#666" 
                               Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="btnColor1" Width="40" Height="40" 
                                Background="#4CAF50" BorderBrush="Transparent" Margin="2"
                                Cursor="Hand" Click="ColorButton_Click" Tag="#4CAF50">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Grid.Column="1" x:Name="btnColor2" Width="40" Height="40" 
                                Background="#3498DB" BorderBrush="Transparent" Margin="2"
                                Cursor="Hand" Click="ColorButton_Click" Tag="#3498DB">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Grid.Column="2" x:Name="btnColor3" Width="40" Height="40" 
                                Background="#E74C3C" BorderBrush="Transparent" Margin="2"
                                Cursor="Hand" Click="ColorButton_Click" Tag="#E74C3C">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Grid.Column="3" x:Name="btnColor4" Width="40" Height="40" 
                                Background="#F39C12" BorderBrush="Transparent" Margin="2"
                                Cursor="Hand" Click="ColorButton_Click" Tag="#F39C12">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Grid.Column="4" x:Name="btnColor5" Width="40" Height="40" 
                                Background="#9B59B6" BorderBrush="Transparent" Margin="2"
                                Cursor="Hand" Click="ColorButton_Click" Tag="#9B59B6">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>

                    <!-- Цель (количество дней в неделю) -->
                    <TextBlock Text="Цель (дней в неделю)" 
                               FontSize="14" 
                               Foreground="#666" 
                               Margin="0,0,0,5"/>

                    <ComboBox x:Name="cmbWeeklyGoal" 
                              Height="40" 
                              FontSize="14"
                              Margin="0,0,0,15"
                              SelectedIndex="6">
                        <ComboBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </ComboBox.Resources>
                        <ComboBoxItem Content="1 день в неделю"/>
                        <ComboBoxItem Content="2 дня в неделю"/>
                        <ComboBoxItem Content="3 дня в неделю"/>
                        <ComboBoxItem Content="4 дня в неделю"/>
                        <ComboBoxItem Content="5 дней в неделю"/>
                        <ComboBoxItem Content="6 дней в неделю"/>
                        <ComboBoxItem Content="Каждый день"/>
                    </ComboBox>

                    <!-- Напоминание -->
                    <CheckBox x:Name="chkReminder" 
                              Margin="0,0,0,10"
                              VerticalAlignment="Center">
                        <TextBlock Text="Установить напоминание" FontSize="14" Foreground="#666"/>
                    </CheckBox>

                    <Grid Margin="0,0,0,15" IsEnabled="{Binding ElementName=chkReminder, Path=IsChecked}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Время:" FontSize="14" Foreground="#666" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" x:Name="txtReminderTime" Text="09:00" Height="35" FontSize="14" Padding="10,0">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки -->
            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" 
                        x:Name="btnCancel" 
                        Content="Отмена" 
                        Height="45" 
                        Margin="0,0,5,0"
                        Background="Transparent" 
                        BorderBrush="#DDD" 
                        BorderThickness="1.5"
                        Foreground="#666"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="btnCancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="1"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F5F5F5"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="1" 
                        x:Name="btnSave" 
                        Content="Сохранить" 
                        Height="45" 
                        Margin="5,0,0,0"
                        Background="#4CAF50" 
                        BorderBrush="Transparent"
                        Foreground="#666"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        IsEnabled="False"
                        Click="btnSave_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="1"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#CCCCCC"/>
                                    <Setter Property="Foreground" Value="#999999"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Подсказка об обязательных полях -->
            <TextBlock Grid.Row="2" Text="* обязательное поле" 
                       FontSize="11" Foreground="#999" 
                       VerticalAlignment="Bottom" HorizontalAlignment="Left"
                       Margin="0,0,0,70"/>
        </Grid>
    </Border>
</Window>